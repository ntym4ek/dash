<?php


/**
 * Implements hook_cron()
 */
function import_cron()
{
  // поставить заявки в очередь на импорт
  if (variable_get('admin_import_enabled', false)) {
    import_queue_incoming_exchange_files();
  }
}

/**
 * Implements hook_cron_queue_info().
 */
function import_cron_queue_info()
{
  $queues['incoming_exchange_queue'] = array(
    'worker callback' => 'import_process_incoming_exchange_file',
  );

  return $queues;
}

function import_queue_incoming_exchange_files()
{
  $directory = 'private://exchange/';
  $queue_path = $directory . 'import_queue';

  // формат массива обработчиков импорта
  $processors = [
    // первая очередь импорта данных, необходимых для второй очереди
    'first_queue' => [
      [
        'mask'    => '/^scrum_td_region.*\.json/',    // маска поиска файла
        'include' => 'file.inc',                      // файл с функцией импорта
        'func'    => 'import_import_regions'          // название функции импорта
      ],
    ],
    // вторая очередь
    'last_queue' => [],
  ];

  $processors = [
    'first_queue' => [
      ['mask' => '/^scrum_td_region.*\.json/',        'func' => 'import_import_regions'],         // -- Справочник Регионов
      ['mask' => '/^scrum_td_clients.*\.json/',       'func' => 'import_import_clients_td'],      // -- Справочник Клиентов ТД
      ['mask' => '/^scrum_dav.*\.json/',              'func' => 'import_import_clients_ah'],      // -- Справочник Клиентов АХ (давальцев)
      ['mask' => '/^scrum_nom.*\.json/',              'func' => 'import_import_nomenklatura'],    // -- Справочник Номенклатуры АХ
      ['mask' => '/^scrum_td_nom.*\.json/',           'func' => 'import_import_nomenklatura_td'], // -- Справочник Номенклатуры ТД
    ],
    // вторая очередь
    'last_queue' => [
      ['mask' => '/^scrum_plan.*\.json/',             'func' => 'import_import_production_plan'], // -- План производства
      ['mask' => '/^scrum_td_payplan.*\.json/',       'func' => 'import_import_pay_plan_td'],     // -- План выручки ТД
      ['mask' => '/^scrum_td_shipplan.*\.json/',      'func' => 'import_import_ship_plan_td'],    // -- План отгрузки ТД
      ['mask' => '/^scrum_revenue.*\.json/',          'func' => 'import_import_revenue'],         // -- Выручка
    ],
  ];

  // дать возможность модулям добавить свой импорт
  drupal_alter('import_processors', $processors);

  $ie_queue = DrupalQueue::get('incoming_exchange_queue');

//  $ie_queue->deleteQueue();

  // получить список файлов по шаблону и добавить в очередь
  foreach($processors as $queue) {
    foreach($queue as $processor) {
      if ($files = file_scan_directory($directory, $processor['mask'], ['recurse' => false], 0)) {
        foreach($files as $file) {
          // перемещаем обнаруженные файлы в папку очереди, чтобы не обнаружить при следующем запуске крона
          if (file_prepare_directory($queue_path, FILE_CREATE_DIRECTORY)) {
            if ($new_uri = file_unmanaged_move($file->uri, $queue_path . '/' . $file->filename)) {
              $file->uri = $new_uri;
              $ie_queue->createItem(['file' => $file, 'processor' => $processor]);
  //            watchdog('import', 'Файл @file поставлен в очередь на импорт.', ['@file' => $file->uri], WATCHDOG_INFO);
            }
          }
        }
      }
    }
  }
}

function import_process_incoming_exchange_file($options)
{
  $directory = 'private://exchange/';

  // импортировать
  $array = drupal_json_decode(file_get_contents($options['file']->uri));

  if (!empty($options['processor']['include'])) require_once $options['processor']['include'];

  if (call_user_func($options['processor']['func'], $array)) {
    $path = $directory . 'success/dash/' . date('Y') . '/' . date('m') . '/' . date('d');
  } else {
    $path = $directory . 'fail/dash/' . date('Y') . '/' . date('m') . '/' . date('d');
  }
  file_prepare_directory($path, FILE_CREATE_DIRECTORY);
  file_unmanaged_move($options['file']->uri, $path . '/' . $options['file']->filename);
}

/**
 * -- функции импорта справочников
 */
function import_import_regions($array)
{
  if (is_array($array) && !empty($array['load'])) {

    foreach ($array['load'] as $region) {
      if ($region['id'] && $region['name']) {

        $term = import_get_region_by_1c_id($region['id']);
        $parent_term = empty($region['parent_id']) ? 0 : import_get_region_by_1c_id($region['parent_id']);

        $term_wr = entity_metadata_wrapper('taxonomy_term', $term);
        $term_wr->field_1c_id = $region['id'];
        $term_wr->parent = [$parent_term->tid ?? 0];
        $term_wr->name = $region['name'];
        $term_wr->save();
      }
    }

    // drupal_set_message('Регионы импортированы.');
    watchdog('import', 'Регионы импортированы.', [], WATCHDOG_INFO);
    return true;
  } else {
    // drupal_set_message('Импорт регионов не выполнен.', 'warning');
    watchdog('import', 'Импорт регионов не выполнен.', [], WATCHDOG_ERROR);
    return false;
  }
}

function import_import_clients_td($array)
{
  if (is_array($array) && !empty($array['load'])) {
    $vid = taxonomy_vocabulary_machine_name_load('clients_td')->vid;

    $new_records = [];
    foreach ($array['load'] as $client) {
      if ($client['id'] && $client['name']) {

        if ($term = import_get_client_by_1c_id('td', $client['id'])) {
          $client_wr = entity_metadata_wrapper('taxonomy_term', $term);
          $client_wr->name = $client['name'];
          $client_wr->field_status = 1;
          if ($region_tid = import_get_region_by_1c_id($client['region_id'])) {
            $client_wr->field_region = $region_tid;
          } else {
            watchdog('import', 'Не найден регион ' . $client['region_id'] . ' при импорте клиентов ТД', [], WATCHDOG_ERROR);
          }
          $client_wr->save();

          $new_records[] = $client_wr->getIdentifier();
        }
      }
    }

    // если полное обновление справочника, то запомнить отсутствующие записи и сделать их неактивными
    if ($array['reload']) {
      $dbr = db_select('taxonomy_term_data', 't');
      $dbr->condition('t.vid', $vid);
      $dbr->addField('t', 'tid');
      $terms_old = $dbr->execute()->fetchAllAssoc('tid');

      foreach ($terms_old as $tid => $term_old) {
        if (!in_array($tid, $new_records)) {
          $term_wr = entity_metadata_wrapper('taxonomy_term', $tid);
          $term_wr->field_status = 0;
          $term_wr->save();
        }
      }
    }

    // drupal_set_message('Клиенты ТД импортированы.');
    watchdog('import', 'Клиенты ТД импортированы.', [], WATCHDOG_INFO);
    return true;
  } else {
    // drupal_set_message('Импорт клиентов ТД не выполнен.', 'warning');
    watchdog('import', 'Импорт клиентов ТД не выполнен.', [], WATCHDOG_ERROR);
    return false;
  }
}

