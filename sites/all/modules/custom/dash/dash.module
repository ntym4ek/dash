//    if (!empty($conditions['noms'])) {
//      $dbr->condition('fn.field_s_nomenklatura_tid', $conditions['noms'], 'IN');
//    }
//    if (!empty($conditions['exclude']['noms'])) {
//      $dbr->condition('fn.field_s_nomenklatura_tid', $conditions['exclude']['noms'], 'NOT IN');
//    }
//    $dbr->leftJoin('field_data_field_nom_nds', 'fnds', 'fnds.entity_id = fn.field_s_nomenklatura_tid');
//    $dbr->addField('fnds', 'field_nom_nds_value', 'nds');

//    $dbr->leftJoin('field_data_field_client', 'fct', 'fct.entity_id = s.id');
//    $dbr->condition(db_or()
//      ->isNull('fct.bundle')
//      ->condition('fct.bundle', 'plan_ship')
//    );
//    $dbr->leftJoin('field_data_field_region', 'fr', 'fr.entity_id = fct.field_client_tid');
//    $dbr->leftJoin('taxonomy_term_data', 'tr', 'tr.tid = fr.field_region_tid');
//    $dbr->addField('tr', 'tid', 'region_tid');
//    $dbr->addField('tr', 'name', 'region_name');
//    if (!empty($conditions['regions'])) {
//      $dbr->condition('fr.field_region_tid', $conditions['regions'], 'IN');
//    }
//    if (!empty($conditions['exclude']['regions'])) {
//      $dbr->condition('fr.field_region_tid', $conditions['exclude']['regions'], 'NOT IN');
//    }

    // для полей, добавленных позже нужно учитывать, что данные могут быть не заданы
    $dbr->leftJoin('field_data_field_s_is_manual', 'fm', 'fm.entity_id = s.id');
    if (empty($conditions['manual'])) {
      $dbr->condition('fm.field_s_is_manual_value', 0);
    } else {
      $dbr->condition('fm.field_s_is_manual_value', 1);
    }
    $dbr->addField('fm', 'field_s_is_manual_value', 'manual');

    $dbr->orderBy('date');
    $result = $dbr->execute()->fetchAll();
  }

  return $result;
}

/**
 *  Вернуть данные по поступлению ДС (сущность cash_income/cash_income)
 *  с учётом заданных параметров.
 *  Таблица на замену plan/plan_revenue.
 *
 * @param $conditions
 *   - company_id* - tid компании kccc
 *   - period - массив ['from' =>, 'to' => не включительно]           * - обязательно
 *   - type - тип записи (план, факт, неотгруженные контракты)
 *   - manual - данные из 1с или ручной ввод (если не задано, то только данные из 1с)
 * @return array|mixed|null
 */
function dash_cash_income_get_by_conditions($conditions)
{
  $fid = drupal_hash_base64(__FUNCTION__ . serialize($conditions));
  $result = &drupal_static($fid);

  if (!isset($result)) {
    $dbr = db_select('eck_cash_income', 'ci');
    $dbr->condition('ci.type', 'cash_income');
    $dbr->addField('ci', 'id');

    $dbr->innerJoin('field_data_field_ci_company', 'fc', 'fc.entity_id = ci.id');
    $dbr->condition('fc.field_ci_company_tid', $conditions['company_id']);
    $dbr->addField('fc', 'field_ci_company_tid', 'company');

    $dbr->innerJoin('field_data_field_ci_type', 'ft', 'ft.entity_id = ci.id');
    if (isset($conditions['type'])) {
      $dbr->condition('ft.field_ci_type_value', $conditions['type']);
    }
    $dbr->addField('ft', 'field_ci_type_value', 'type');

    $dbr->innerJoin('field_data_field_ci_date', 'frd', 'frd.entity_id = ci.id');
    $dbr->condition('frd.field_ci_date_value', $conditions['period']['from'], '>=');
    $dbr->condition('frd.field_ci_date_value', $conditions['period']['to'], '<');
    $dbr->addField('frd', 'field_ci_date_value', 'date');

    $dbr->innerJoin('field_data_field_ci_amount', 'fa', 'fa.entity_id = ci.id');
    $dbr->addField('fa', 'field_ci_amount_value', 'amount');

    $dbr->innerJoin('field_data_field_ci_is_manual', 'fm', 'fm.entity_id = ci.id');
    if (empty($conditions['manual'])) {
      $dbr->condition('fm.field_ci_is_manual_value', 0);
    } else {
      $dbr->condition('fm.field_ci_is_manual_value', 1);
    }
    $dbr->addField('fm', 'field_ci_is_manual_value', 'manual');

    $dbr->orderBy('date');
    $result = $dbr->execute()->fetchAll();
  }

  return $result;
}

/**
 *  Удалить данные по поступлению ДС (сущность cash_income/cash_income)
 *  с учётом заданных параметров.
 *
 * @param $conditions
 *   - company_id* - tid компании kccc
 *   - month_start - массив ['from' =>, 'to' => не включительно]           * - обязательно
 *   - type - тип записи (план, факт, неотгруженные контракты)
 *   - manual - данные из 1с или ручной ввод (если не задано, то только данные из 1с)
 * @return array|mixed|null
 */
function dash_cash_income_delete_by_month($conditions)
{
  if ($conditions['company_id'] && $conditions['month_start'] && $conditions['type'] && $conditions['manual']) {
    $next_month_start = gmmktime(0, 0, 0, date('n', $conditions['month_start'])+1, 1, date('Y', $conditions['month_start']));

    $efquery = new EntityFieldQuery();
    $efquery
      ->entityCondition('entity_type', 'cash_income')
      ->entityCondition('bundle', 'cash_income')
      ->fieldCondition('field_ci_date', 'value', $conditions['month_start'], '>=')
      ->fieldCondition('field_ci_date', 'value', $next_month_start, '<')
      ->fieldCondition('field_ci_company', 'value', $conditions['company_id'])
      ->fieldCondition('field_ci_type', 'value', $conditions['type'])
      ->fieldCondition('field_ci_is_manual', 'value', $conditions['manual']);

    $result = $efquery->execute();
    if ($result) {
      entity_delete_multiple('cash_income', array_keys($result['cash_income']));
    }
  }
}

