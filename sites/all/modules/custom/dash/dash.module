<?php

define ('DASH_REV_DIVIDER', 1000000);       // делитель для единиц выручки
define ('DASH_REV_SUFFIX', 'млн руб.');     // суффикс (ед. изм.) для отгрузки
define ('DASH_PROD_DIVIDER', 1000);         // делитель для единиц выручки
define ('DASH_PROD_SUFFIX', 'тыс. ед.');    // суффикс (ед. изм.) для производства

define ('DASH_TYPE_PLAN_DEPR', 0);               // тип План
define ('DASH_TYPE_FACT_DEPR', 1);               // тип Факт
define ('DASH_TYPE_DEAL_DEPR', 2);               // тип Неоплаченный контракт

define ('DASH_COLOR_BLUE', '#2B94C9');
define ('DASH_COLOR_LIGHT_BLUE', '#89BDDF');
define ('DASH_COLOR_AQUA', '#2DAD9E');
define ('DASH_COLOR_GREEN', '#47AD9E');
define ('DASH_COLOR_GLOW_GREEN', '#A6B727');
define ('DASH_COLOR_LIGHT_GREEN', '#a6c96a');
define ('DASH_COLOR_RED', '#DF5327');
define ('DASH_COLOR_DARK_RED', '#c42525');
define ('DASH_COLOR_ORANGE', '#F69200');
define ('DASH_COLOR_LIGHT_ORANGE', '#FFC000');
define ('DASH_COLOR_PURPLE', '#CD5B8F');

define ('DASH_COLOR_SET_1', [DASH_COLOR_RED, DASH_COLOR_DARK_RED, DASH_COLOR_ORANGE, DASH_COLOR_LIGHT_ORANGE, DASH_COLOR_PURPLE]);
define ('DASH_COLOR_SET_2', [DASH_COLOR_BLUE, DASH_COLOR_LIGHT_BLUE, DASH_COLOR_AQUA, DASH_COLOR_GLOW_GREEN, DASH_COLOR_LIGHT_GREEN]);

define ('DASH_HISTORY_LENGTH', 5);            // максимальное количество лет истории
define ('DASH_HISTORY_START_YEAR_TD', 2020);  // начало истории сезонов ТД, год
define ('DASH_PERIOD_START_MONTH_TD', 10);    // начало сезона, месяц

define ('DASH_INN_AH', '4312128282');
define ('DASH_INN_TD', '4312138026');
define ('DASH_INN_ST', '4312136043');
const DASH_TD_NOM_ID_LIST_TO_EXCLUDE = [      // ТД, часть номенклатуры не нужно отражать в отчётах
  11743,                                          // 2 Этилгексиловый эфир 2,4-Д кислоты(ТД КЧХК)
  193930,                                         // 2,4-Д 2-этилгексиловый эфир техн. Китай (ТД КЧХК)
  194629,                                         // 2,4-D-кислота
  194367,194370,194371,194366,11745,11747,11746,  // этикетки
];
 const DASH_TYPE_PLAN = 1;                      // тип План
 const DASH_TYPE_FACT = 2;                      // тип Факт
 const DASH_TYPE_DEAL = 3;                      // тип Неоплаченный контракт

// вид Задолженности для таблицы Кредиты и задолженности
const DASH_DEBT_KIND_DEBITOR = 1;              // Дебиторская задолженность
const DASH_DEBT_KIND_CREDITOR = 2;             // Кредиторская задолженность
const DASH_DEBT_KIND_CREDIT = 3;               // внешние Кредиты
const DASH_DEBT_KIND_LOAN = 4;                 // внутренние займы

// Агрохимикат
define ('DASH_HISTORY_START_YEAR_AH', 2020);  // год начала статистики
define ('DASH_PERIOD_START_MONTH_AH', 1);     // месяц, с которого начинается период отчётности

date_default_timezone_set('UTC');

/**
 * Implementation of hook_menu().
 */
function dash_menu()
{
  $items['td'] = array(
    'title' => 'Торговый Дом',
    'menu_name' => 'main-menu',
    'page callback' => 'dash_frontpage',
    'expanded' => true,
    'access callback' => 'ext_user_has_roles',
    'access arguments' => [[ADMIN_RID, TRADE_HOUSE_USER_RID, DEP_2V2G_USER_RID, DEP_2A_USER_RID, DEP_4_USER_RID, DEP_7_USER_RID]],
  );

  $items['ajax-load'] = array(
    'page callback' => 'dash_ajax_load',
    'access callback' => 'ext_user_has_roles',  // todo доступ нужно проверять на уровне функции, иначе роли из списка могут получить данные друг друга
    'access arguments' => [[ADMIN_RID, TRADE_HOUSE_USER_RID, DEP_2V2G_USER_RID]],
    'type' => MENU_CALLBACK,
  );

  return $items;
}

function dash_frontpage()
{
  // Используется при клике по корневому Торговый Дом в меню.
  // Так как главная у всех разная за счёт модуля Home Links,
  // отправляем на неё.
  drupal_goto('<front>');
}

function dash_chart_definition_alter(&$element, $chart)
{
  if (isset($element["options"]["series"])) {
    foreach ($element["options"]["series"] as &$el) {
      $el["_format"]["format"] = '#,###';
    }
  }
  if (isset($element["options"]["vAxes"][0])) {
    $element["options"]["vAxes"][0]["format"] = 'decimal';
  }
}

/**
* ----- универсальные для AH и TD графики ------------------------------------------------------------------------------
*/

/**
 * Сравнение выручки период к периоду
 * Внутри года суммируются данные за заданный период включительно
 * @param $time_from -начало периода, обязательно текущего
 * @param $time_to - конец периода, обязательно текущего
 */
function dash_column_revenue_period_to_period($company, $time_from, $time_to, $revenue_type = null)
{
  $data = [];

  // собрать данные периодов с DASH_YEAR_HISTORY_START года
  $years_shift = date('Y', $time_from) - ($company  == 'td' ? DASH_HISTORY_START_YEAR_TD : DASH_HISTORY_START_YEAR_AH);
  $years_shift = abs($years_shift)+1 > DASH_HISTORY_LENGTH ? DASH_HISTORY_LENGTH : $years_shift;
  do {
    $time_start = gmmktime(0, 0, 0,  date('n', $time_from)-12*$years_shift, date('j', $time_from), date('Y', $time_from));
    $time_end = gmmktime(0, 0, 0,  date('n', $time_to)-12*$years_shift, date('j', $time_to), date('Y', $time_to));

    $dbr = db_select('eck_revenue', 'r');
    $dbr->innerJoin('field_data_field_revenue_amount', 'fra', 'fra.entity_id = r.id');
    $dbr->condition('fra.bundle', 'revenue');
    $dbr->innerJoin('field_data_field_revenue_company', 'fc', 'fc.entity_id = r.id');
    $dbr->condition('fc.field_revenue_company_value', $company);
    $dbr->innerJoin('field_data_field_revenue_date', 'frd', 'frd.entity_id = r.id');
    $dbr->condition('frd.bundle', 'revenue');
    $dbr->condition('frd.field_revenue_date_value', $time_start, '>=');
    $dbr->condition('frd.field_revenue_date_value', $time_end, '<');
    $dbr->addExpression('SUM(fra.field_revenue_amount_value)', 'amount');
    $dbr->innerJoin('field_data_field_revenue_type', 'frt', 'frt.entity_id = r.id');
    $dbr->condition('frt.field_revenue_type_value', 'Прочая реализация', '!=');
    if ($revenue_type) {
//      $dbr->innerJoin('field_data_field_revenue_type', 'frt', 'frt.entity_id = r.id');
      $dbr->condition('frt.field_revenue_type_value', $revenue_type, 'IN');
    }
    $data[date('Y', $time_start)] = [
      'time_start' => $time_start,
      'time_end' => $time_end,
      'amount' => $dbr->execute()->fetchField() / DASH_REV_DIVIDER
    ];

    $years_shift--;
  } while ($years_shift >= 0);

  if ($revenue_type) {
    $title = 'Отгрузка по категории "' . $revenue_type[0] . '" (' . DASH_REV_SUFFIX . ')';
    $colors = [DASH_COLOR_RED, DASH_COLOR_PURPLE, DASH_COLOR_ORANGE, DASH_COLOR_DARK_RED, DASH_COLOR_AQUA, DASH_COLOR_GLOW_GREEN,  DASH_COLOR_BLUE];
  } else {
    $title = 'Суммарная отгрузка по данным бухгалтерии (' . DASH_REV_SUFFIX . ')';
    $colors = [];
  }

  $chart = array(
    '#type' => 'chart',
    '#chart_type' => 'column',
    '#title' => $title,
    '#height' => '350',
    '#data_labels' => TRUE,
    '#legend_position' => 'bottom',
    'yaxis' => [
      '#type' => 'chart_yaxis',
      '#min' => 0,
      '#raw_options' => ['textStyle' => ['fontName' => '<global-font-name>']],
    ],
    '#raw_options' => [
      'titleTextStyle' => ['bold' => 'true', 'fontName' => '<global-font-name>', 'fontSize' => '16'],
      'chartArea' => [
        'width' => '85%',
        'height' => '70%',
        'left' => 50,
      ],
    ],
  );

  if ($colors) $chart += ['#colors' => $colors];

  $year_prev = $delta = null;
  foreach ($data as $year => $item) {
    $chart[$year] = [
      '#type' => 'chart_data',
      '#title' => (string)(date('Y', $time_from) == date('Y', $time_to-1) ? $year : date('Y', $item['time_start']) . '-' . date('y', $item['time_end'])),
      '#data' => [$item['amount']],
    ];
    if ($year_prev && $data[$year_prev]) {
      $delta = ($item['amount'] > $data[$year_prev]['amount'] ? '+' : '') . number_format(($item['amount']/$data[$year_prev]['amount']*100)-100, 0, null, ' ') . '%';
    }
    $chart[$year][0] = [
      '#type' => 'chart_data_item',
      '#raw_options' => [
        'annotation' => number_format($item['amount'], 0, '', ' ') . ($delta ? ' (' . $delta . ')' : ''),
      ],
    ];
    $year_prev = $year;
  }

  return $chart;
}

function dash_pie_revenue_year($company, $time_from, $time_to)
{
  $dbr = db_select('eck_revenue', 'r');
  $dbr->innerJoin('field_data_field_revenue_company', 'fc', 'fc.entity_id = r.id');
  $dbr->condition('fc.field_revenue_company_value', $company);
  $dbr->innerJoin('field_data_field_revenue_type', 'frt', 'frt.entity_id = r.id');
  $dbr->addField('frt', 'field_revenue_type_value', 'type');
  $dbr->innerJoin('field_data_field_revenue_amount', 'fra', 'fra.entity_id = r.id');
  $dbr->condition('fra.bundle', 'revenue');
  $dbr->groupBy('frt.field_revenue_type_value');
  $dbr->innerJoin('field_data_field_revenue_date', 'frd', 'frd.entity_id = r.id');
  $dbr->condition('frd.bundle', 'revenue');
  $dbr->condition('frd.field_revenue_date_value', $time_from, '>=');
  $dbr->condition('frd.field_revenue_date_value', $time_to, '<');
  $dbr->addExpression('SUM(fra.field_revenue_amount_value)', 'amount');
  $results = $dbr->execute()->fetchAll();

  $total = 0;
  $rev_by_types = [];
  $types_to_unite = dash_types_to_merge_get();
  foreach($results as $item) {
    $total += $item->amount;
    $type = $types_to_unite[$item->type] ?? $item->type;
    if (!isset($rev_by_types[$type])) $rev_by_types[$type] = 0;
    $rev_by_types[$type] += $item->amount;
  }
  $total = $total/DASH_REV_DIVIDER;

  $types = [];
  $types_data = [];
  $other = 0;
  foreach($rev_by_types as $type => $amount) {
    // выводим значения больше 4% от общей суммы
    $amount = $amount/DASH_REV_DIVIDER;
    if ($amount/$total*100 > 4 || $type == 'Услуги хранения') {
      $types[$amount] = $type;
      $types_data[$amount] = $amount;
    } else {
      $other += $amount;
    }
  }
  if ($other) {
    $types[$other] = 'Прочее';
    $types_data[$other] = $other;
  }

  krsort($types);
  krsort($types_data);

  $period = '';
  if (date('Y', $time_to) != date('Y')) {
    $period = (date('Y', $time_from) == date('Y', $time_to - 1) ? date('Y', $time_from) : date('Y', $time_from) . '-' . date('y', $time_to)) . ' года ';
  }

  $chart = array(
    '#type' => 'chart',
    '#title' => 'Структура отгрузки за период ' . $period . 'по данным бухгалтерии (' . DASH_REV_SUFFIX . ')',
//    '#title_position' => 'center',
    '#chart_type' => 'pie',
    '#legend_position' => 'right',
    '#legend_title_font_size' => '10px',
    '#data_labels' => TRUE,
    '#tooltips' => TRUE,
    '#height' => '350',
    '#raw_options' => [
      'titleTextStyle' => ['bold' => 'true', 'fontName' => '<global-font-name>', 'fontSize' => '16'],
      'legend' => ['textStyle' => ['fontSize' => '14', 'fontName' => '<global-font-name>']],
      'chartArea' => ['width' => '85%'],
    ],
  );
  $chart['pie_data'] = array(
    '#type' => 'chart_data',
    '#title' => 'Продукция',
    '#labels' => array_values($types),
    '#data' => array_values($types_data),
  );

  return $chart;
}

function dash_column_revenue_by_types($company, $time_from, $time_to)
{
  $types_to_unite = dash_types_to_merge_get();

  // получаем возможные типы продукции
  $dbr = db_select('eck_revenue', 'r');
  $dbr->innerJoin('field_data_field_revenue_type', 'frt', 'frt.entity_id = r.id');
  $dbr->addField('frt', 'field_revenue_type_value');
  $dbr->innerJoin('field_data_field_revenue_company', 'fc', 'fc.entity_id = r.id');
  $dbr->condition('fc.field_revenue_company_value', $company);
  $dbr->innerJoin('field_data_field_revenue_date', 'frd', 'frd.entity_id = r.id');
  $dbr->condition('frd.bundle', 'revenue');
  $dbr->distinct();
  $types = $dbr->execute()->fetchCol();

  // собираем по типам за все сезоны
  $rev_by_types = [];
  foreach($types as $type) {
    // собрать данные периодов с DASH_YEAR_HISTORY_START года (именно этот график для ТД берём с 2021, так как в 1с не получается разделить продукцию 2020 года)
    $amounts = [];
    $years_shift = date('Y', $time_from) - ($company == 'td' ? 2021 : DASH_HISTORY_START_YEAR_AH);
    $years_shift = abs($years_shift)+1 > DASH_HISTORY_LENGTH ? DASH_HISTORY_LENGTH : $years_shift;
    do {
      $time_start = gmmktime(0, 0, 0,  date('n', $time_from)-12*$years_shift, date('j', $time_from), date('Y', $time_from));
      $time_end = gmmktime(0, 0, 0,  date('n', $time_to)-12*$years_shift, date('j', $time_to), date('Y', $time_to));

      $dbr = db_select('eck_revenue', 'r');
      $dbr->innerJoin('field_data_field_revenue_type', 'frt', 'frt.entity_id = r.id');
      $dbr->condition('frt.field_revenue_type_value', $type);
      $dbr->innerJoin('field_data_field_revenue_company', 'fc', 'fc.entity_id = r.id');
      $dbr->condition('fc.field_revenue_company_value', $company);
      $dbr->innerJoin('field_data_field_revenue_amount', 'fra', 'fra.entity_id = r.id');
      $dbr->condition('fra.bundle', 'revenue');
      $dbr->innerJoin('field_data_field_revenue_date', 'frd', 'frd.entity_id = r.id');
      $dbr->condition('frd.bundle', 'revenue');
      $dbr->condition('frd.field_revenue_date_value', $time_start, '>=');
      $dbr->condition('frd.field_revenue_date_value', $time_end, '<');
      $dbr->addExpression('SUM(fra.field_revenue_amount_value)', 'amount');
      $amounts[date('Y', $time_start)] = $dbr->execute()->fetchField()/DASH_REV_DIVIDER;

      $years_shift--;
    } while ($years_shift >= 0);

    // если какие-то группы нужно объединить, определяем целевой тип
    $type = isset($types_to_unite[$type]) ? $types_to_unite[$type] : $type;

    foreach($amounts as $year => $amount) {
      if (!isset($rev_by_types[$type])) $rev_by_types[$type] = [];
      if (!isset($rev_by_types[$type][$year])) $rev_by_types[$type][$year] = 0;
      $rev_by_types[$type][$year] += $amount;
    }
  }

  // подготовить массив и отсортировать по выручке последнего отчётного периода
  $rev_by_amount = [];
  foreach($rev_by_types as $type => $amounts) {
    $amount_curr = $amounts[date('Y', $time_from)];

    $rev_by_amount[$amount_curr] = [
      'type' => $type,
      'amounts' => $amounts
    ];
  }
  krsort($rev_by_amount);

  $total = 0;
  foreach($rev_by_amount as $amount => $item) {
    $total += $amount;
  }
  foreach($rev_by_amount as $amount => $item) {
    // выводим значения больше 4% от общей суммы
    if ($total && $amount/$total*100 <= 4) {
      unset($rev_by_amount[$amount]);
    }
  }

  $chart = array(
    '#type' => 'chart',
    '#chart_type' => 'column',
    '#title' => 'Отгрузка по основным видам продукции по данным бухгалтерии (' . DASH_REV_SUFFIX . ')',
    '#legend_position' => 'bottom',
    '#height' => '400',
    'xaxis' => [
      '#type' => 'chart_xaxis',
      '#labels' => [],
      '#raw_options' => ['textStyle' => ['fontName' => '<global-font-name>']],
    ],
    'yaxis' => [
      '#type' => 'chart_yaxis',
      '#raw_options' => ['textStyle' => ['fontName' => '<global-font-name>']],
    ],
    '#raw_options' => [
      'titleTextStyle' => ['bold' => 'true', 'fontName' => '<global-font-name>', 'fontSize' => '16'],
      'bar' => ['groupWidth' => "61%"],
      'legend' => [ 'position' => 'bottom', 'textStyle' => ['fontSize' => '13', 'fontName' => '<global-font-name>'] ],
      'chartArea' => [
        'width' => '95%',
        'height' => '70%',
        'left' => 50,
      ],
    ],
  );

  foreach($rev_by_amount as $rt) {
    $chart['xaxis']['#labels'][] = $rt['type'];
  }

  $year_prev = 0;
  $i = 0;
  foreach($rev_by_amount as &$rt) {
    ksort($rt['amounts']);

    foreach($rt['amounts'] as $year => $amount) {

      if (!isset($chart[$year])) {
        $chart[$year] = array(
          '#type' => 'chart_data',
          '#title' => (string)$year,
          '#data' => [],
        );
      }
      $delta = empty($rt['amounts'][$year_prev]) ? '' : ($rt['amounts'][$year] > $rt['amounts'][$year_prev] ? '+' : '') . number_format(($rt['amounts'][$year]/$rt['amounts'][$year_prev]*100)-100, 0, null, ' ') . '%';
      $year_prev = $year;

      $chart[$year]['#data'][] = $rt['amounts'][$year];
      $chart[$year][$i] = array(
        '#type' => 'chart_data_item',
        '#raw_options' => [
          'annotation' => number_format($rt['amounts'][$year], 0, '', ' ') . ($delta ? ' (' . $delta . ')' : ''),
        ],
      );
    }
    $i++;
    $year_prev = 0;
  }

  return $chart;
}


/**
 * ----- Выборка данных ------------------------------------------------------------------------------------------------
 */

/**
 *  Вернуть данные по ОТГРУЗКЕ продукции (сущность plan/plan_ship)
 *  с учётом заданных параметров
 * @param $conditions
 *   - type - тип записи (план, факт, неотгруженные контракты)
 *   - manual (bool) - данные из 1с или ручной ввод (если не задано, то только данные из 1с)
 *   - period - массив ['from' => , 'to' => не включительно]
 *   - noms - массив ID номенклатуры, которые нужно отобрать
 *   - regions - массив ID регионов, которые нужно отобрать
 *   - exclude - массив условий, которые нужно исключить
 *     - noms - массив ID номенклатуры, которые нужно исключить
 *     - regions - массив ID регионов, которые нужно исключить
 * @return array|mixed|null
 */
function dash_plan_ship_get_by_conditions($conditions)
{
  $fid = drupal_hash_base64(__FUNCTION__ . serialize($conditions));
  $result = &drupal_static($fid);

  if (!isset($result)) {
    $dbr = db_select('eck_plan', 'p');
    $dbr->condition('p.type', 'plan_ship');
    $dbr->addField('p', 'id');

    $dbr->innerJoin('field_data_field_record_type_td', 'frt', 'frt.entity_id = p.id');
    $dbr->condition('frt.bundle', 'plan_ship');
    $dbr->condition('frt.field_record_type_td_value', $conditions['type']);

    $dbr->innerJoin('field_data_field_date', 'frd', 'frd.entity_id = p.id');
    $dbr->condition('frd.bundle', 'plan_ship');
    if (!empty($conditions['period'])) {
      $dbr->condition('frd.field_date_value', $conditions['period']['from'], '>=');
      $dbr->condition('frd.field_date_value', $conditions['period']['to'], '<');
    }
    $dbr->addField('frd', 'field_date_value', 'date');

    $dbr->leftJoin('field_data_field_quantity_td', 'fq', 'fq.entity_id = p.id');
    $dbr->condition(db_or()
      ->isNull('fq.bundle')
      ->condition('fq.bundle', 'plan_ship')
    );
    $dbr->addField('fq', 'field_quantity_td_value', 'qty');

    $dbr->leftJoin('field_data_field_amount', 'fa', 'fa.entity_id = p.id');
    $dbr->condition(db_or()
      ->isNull('fa.bundle')
      ->condition('fa.bundle', 'plan_ship')
    );
    $dbr->addField('fa', 'field_amount_value', 'amount');

    $dbr->leftJoin('field_data_field_net_cost', 'fnc', 'fnc.entity_id = p.id');
    $dbr->condition(db_or()
      ->isNull('fnc.bundle')
      ->condition('fnc.bundle', 'plan_ship')
    );
    $dbr->addField('fnc', 'field_net_cost_value', 'net_cost');

    $dbr->leftJoin('field_data_field_nomenklatura', 'fn', 'fn.entity_id = p.id');
    $dbr->condition(db_or()
      ->isNull('fn.bundle')
      ->condition('fn.bundle', 'plan_ship')
    );
    $dbr->condition('fn.field_nomenklatura_tid', DASH_TD_NOM_ID_LIST_TO_EXCLUDE, 'NOT IN');
    $dbr->leftJoin('taxonomy_term_data', 't', 't.tid = fn.field_nomenklatura_tid');
    $dbr->fields('t', ['tid', 'name']);
    if (!empty($conditions['noms'])) {
      $dbr->condition('fn.field_nomenklatura_tid', $conditions['noms'], 'IN');
    }
    if (!empty($conditions['exclude']['noms'])) {
      $dbr->condition('fn.field_nomenklatura_tid', $conditions['exclude']['noms'], 'NOT IN');
    }

    $dbr->leftJoin('field_data_field_nom_nds', 'fnds', 'fnds.entity_id = fn.field_nomenklatura_tid');
    $dbr->addField('fnds', 'field_nom_nds_value', 'nds');

    $dbr->leftJoin('field_data_field_client', 'fct', 'fct.entity_id = p.id');
    $dbr->condition(db_or()
      ->isNull('fct.bundle')
      ->condition('fct.bundle', 'plan_ship')
    );
    $dbr->leftJoin('field_data_field_region', 'fr', 'fr.entity_id = fct.field_client_tid');
    $dbr->leftJoin('taxonomy_term_data', 'tr', 'tr.tid = fr.field_region_tid');
    $dbr->addField('tr', 'tid', 'region_tid');
    $dbr->addField('tr', 'name', 'region_name');
    if (!empty($conditions['regions'])) {
      $dbr->condition('fr.field_region_tid', $conditions['regions'], 'IN');
    }
    if (!empty($conditions['exclude']['regions'])) {
      $dbr->condition('fr.field_region_tid', $conditions['exclude']['regions'], 'NOT IN');
    }

    // для полей, добавленных позже нужно учитывать, что данные могут быть не заданы
    $dbr->leftJoin('field_data_field_is_manual', 'fm', 'fm.entity_id = p.id');
    $dbr->condition(db_or()
      ->isNull('fm.bundle')
      ->condition('fm.bundle', 'plan_ship')
    );
    if (isset($conditions['manual']) && $conditions['manual']) {
      $dbr->condition('fm.field_is_manual_value', 1);
    } else {
      $dbr->condition(db_or()
        ->isNull('fm.field_is_manual_value')
        ->condition('fm.field_is_manual_value', 0)
      );
    }
    $dbr->addField('fm', 'field_is_manual_value', 'manual');

    $dbr->orderBy('date');
    $result = $dbr->execute()->fetchAll();
  }

  return $result;
}

/**
