  ];
}

/**
 * Возвращает список месяцев (unix начало и конец) для Периода на входе
 * @param $period
 * @return array
 */
function dash_get_months_list($period)
{
  // список месяцев, за которые выводим график
  $time_months_list = [];
  $time_month_start = $period['from'];
  while($time_month_start < $period['to']) {
    $time_month_end = gmmktime(0, 0, 0, date('n', $time_month_start)+1, 1, date('Y', $time_month_start));
    $time_months_list[] = [
      'start' => $time_month_start,
      'end' => $time_month_end,
    ];
    $time_month_start = $time_month_end;
  }

  return $time_months_list;
}

/**
 * Возвращает список недель (unix начало и конец) для Периода на входе
 * @param $period
 * @return array
 */
function dash_get_weeks_list($period)
{
  $time_weeks_list = [];

  // начальная неделя + 2 дня (начало нашей недели в среду)
  $week_num = date('W', $period['from']);
  $year = date('Y', $period['from']);
  $week_start =  gmmktime(0,0,0,1,1, $year) + $week_num * 7 * 86400 - date('N', gmmktime(0,0,0,1,1,$year)) * 86400 + 3*86400;

  // далее список +7 дней
  while($week_start < $period['to']) {
    $week_end =  $week_start + 7 * 86400;
    if ($week_start < $period['from']) $week_start = $period['from'];
    if ($week_end > $period['to']) $week_end = $period['to'];

    $time_weeks_list[] = [
      'start' => $week_start,
      'end' => $week_end,
    ];
    $week_start = $week_end;
  }

  return $time_weeks_list;
}

/**
 * Возвращает потомков термина на входе
 * @param $parent_tid
 * @return array
 */
function dash_get_term_siblings($parent_tid)
{
  $result = [$parent_tid];

  if ($parent_term = taxonomy_term_load($parent_tid)) {
    foreach (taxonomy_get_tree($parent_term->vid, $parent_tid) as $terms) {
      $result[] = $terms->tid;
    }
  }

  return $result;
}

/**
 * Ищет и возвращает запись по 1с ID из справочника $vid.
 * Создаёт и возвращает пустую новую, если запись не найдена.
 * @param $voc - vid словаря или его наименование
 * @param $record_1c_id
 * @return false|int|mixed
 */
function dash_get_term_by_1c_id($voc, $record_1c_id)
{
  $vid = is_numeric($voc) ? $voc : taxonomy_vocabulary_machine_name_load($voc)->vid;

  if ($vid && $record_1c_id) {
    $query = new EntityFieldQuery();
    $terms = $query
      ->entityCondition('entity_type', 'taxonomy_term')
      ->propertyCondition('vid', $vid)
      ->fieldCondition('field_1c_id', 'value', $record_1c_id)
      ->execute();
    if ($terms) {
      $term = current($terms['taxonomy_term']);
    } else {
      $term = (object)array(
        'vid' => $vid,
        'name' => '',
        'field_1c_id' => ['und' => [0 => ['value' => $record_1c_id]]],
      );
      taxonomy_term_save($term);
    }
    $entities = entity_load('taxonomy_term', [$term->tid]);
  }
  return empty($entities) ? 0: current($entities);
}

/**
 * Удалить Остатки за период
 * @param $date_start
 * @param $date_end
 * @return void
 */
function dash_remains_period_delete($date_start, $date_end)
{
  if ($date_start && $date_end) {
    $efquery = new EntityFieldQuery();
    $efquery
      ->entityCondition('entity_type', 'remains')
      ->entityCondition('bundle', 'remains')
      ->fieldCondition('field_date', 'value', $date_start, '>=')
      ->fieldCondition('field_date', 'value', $date_end, '<');

    $result = $efquery->execute();
    if ($result) {
      entity_delete_multiple('remains', array_keys($result['remains']));
    }
  }

}

function dash_get_registration_by_1c_id($reg_1c_id)
{
  if ($reg_1c_id) {
    $query = new EntityFieldQuery();
    $regs = $query
      ->entityCondition('entity_type', 'registration')
      ->fieldCondition('field_1c_id', 'value', $reg_1c_id)
      ->execute();
    if ($regs) {
      $reg = current($regs['registration']);
    } else {
      $reg = entity_create('registration', [
        'type' => 'registration',
        'field_1c_id' => ['und' => [0 => ['value' => $reg_1c_id]]],
      ]);
      entity_save('registration', $reg);
    }
    $entities = entity_load('registration', [$reg->id]);
  }
  return empty($entities) ? 0: current($entities);
}

function dash_get_no_data_chart($title = null)
{
  return [
    '#type' => 'chart',
    '#title' => $title ?? '',
    '#chart_type' => 'pie',
    '#height' => '200',
    '#width' => '400',
    'pie_data' => [
      '#type' => 'chart_data',
      '#title' => 'Продукция',
      '#labels' => [],
      '#data' => []
    ],
    '#raw_options' => [
      'titleTextStyle' => ['bold' => 'true', 'fontName' => '<global-font-name>', 'fontSize' => '16'],
    ],
  ];
}

function dash_ajax_load()
{
  $result = '';
  $module = $_GET['module'];
  $func = $_GET['func'];
  include_once (drupal_get_path('module', $module) . '/' . $module . '.module');
  $function = $module . '_' . $func;
  if (function_exists($function)) {
    $result = $function();
  }

  print $result;
  drupal_exit();
}
