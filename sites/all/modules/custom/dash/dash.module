/**
 * Удалить Остатки за период
 * @param $date_start
 * @param $date_end
 * @return void
 */
function dash_remains_delete_by_period($date_start, $date_end)
{
  if ($date_start && $date_end) {
    $efquery = new EntityFieldQuery();
    $efquery
      ->entityCondition('entity_type', 'remains')
      ->entityCondition('bundle', 'remains')
      ->fieldCondition('field_rm_date', 'value', $date_start, '>=')
      ->fieldCondition('field_rm_date', 'value', $date_end, '<');

    $result = $efquery->execute();
    if ($result) {
      entity_delete_multiple('remains', array_keys($result['remains']));
    }
  }

}

function dash_registration_get_by_1c_id($reg_1c_id)
{
  if ($reg_1c_id) {
    $query = new EntityFieldQuery();
    $regs = $query
      ->entityCondition('entity_type', 'registration')
      ->fieldCondition('field_1c_id', 'value', $reg_1c_id)
      ->execute();
    if ($regs) {
      $reg = current($regs['registration']);
    } else {
      $reg = entity_create('registration', [
        'type' => 'registration',
        'field_1c_id' => ['und' => [0 => ['value' => $reg_1c_id]]],
      ]);
      entity_save('registration', $reg);
    }
    $entities = entity_load('registration', [$reg->id]);
  }
  return empty($entities) ? 0: current($entities);
}

