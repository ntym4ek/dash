/**
 * Обеспечивает выполнение запроса к заданной функции и возврат разметки с результатом
 */
function dash_ajax_load()
{
  $result = '';
  $module = $_GET['module'];
  $func = $_GET['func'];
  // Функция должна иметь префикс block_ в составе
  // для защиты от подмены функции.
  if (strpos($func, 'block_') !== false) {
    include_once(drupal_get_path('module', $module) . '/' . $module . '.module');
    $function = $module . '_' . $func;
    if (function_exists($function)) {
      $result = $function();
    }
  }

  print $result;
  drupal_exit();
}

function dash_preprocess_page(&$vars)
{
  // Для прорисовки графиков после загрузки их через ajax.
  // Подключаем вручную, тк стандартный модуль подключает её только при наличии графиков на странице,
  // а у нас одни обёртки
  drupal_add_library('charts_google', 'charts_google');

  // установить заголовки для страниц
  if (arg(0) == 'ah') {
    $vars['banner_title'] = 'Агрохимикат';
  }
  if (arg(0) == 'td') {
    $vars['banner_title'] = 'Торговый Дом';
  }
  if (arg(0) == 'fn') {
    $vars['banner_title'] = 'Финансы';
  }
}

/**
 * Вернуть смещение с заданного периода до DASH_YEAR_HISTORY_START года, но не более DASH_HISTORY_LENGTH
 */
function dash_years_shift_get($period = null)
{
  if (!$period) $period = dash_year_time_bounds_get(DASH_PERIOD_START_MONTH_TD);

  $years_shift = date('Y', $period['from']) - (DASH_HISTORY_START_YEAR_TD+1);
  return abs($years_shift)+1 > DASH_HISTORY_LENGTH ? DASH_HISTORY_LENGTH : $years_shift;
}

/**
 * Вернуть список смещений с заданного периода до DASH_YEAR_HISTORY_START года, но не более DASH_HISTORY_LENGTH
 * (например, за 3 года с текущего = [-2, -1, 0])
 */
function dash_years_shift_list_get($period = null, $month_num_start = DASH_PERIOD_START_MONTH_TD)
{
  if (!$period) $period = dash_year_time_bounds_get($month_num_start);

  $period_current = dash_year_time_bounds_get($month_num_start);

  $shift = (date('Y', $period_current['from']) - date('Y', $period['from'])) * (-1);
  $count = date('Y', $period['from']) - $month_num_start;
  $count = $count > DASH_HISTORY_LENGTH ? DASH_HISTORY_LENGTH : $count;

  $shifts = [];
  do {
    $shifts[] = $shift--;
  } while ($count-- > 0);

  return array_reverse($shifts);
}

/**
 * Определить, является ли заданный период текущим
 */
function dash_is_current_season($period)
{
  return $period['from'] < REQUEST_TIME && REQUEST_TIME < $period['end'];
}

/**
 * Вернуть отсортированный по имени список опций для селекта формы
 * @param $voc_name - имя словаря
 * @param $default_options - начальные опции, например 'all' => 'Все'
 */
function dash_form_options_get_from_taxonomy($voc_name, $default_options = null)
{
  if ($voc = taxonomy_vocabulary_machine_name_load($voc_name)) {
    if ($terms = taxonomy_get_tree($voc->vid)) {
      foreach ($terms as $term) {
        $options[$term->name] = $term->tid;
      }
    }
  }
  ksort($options);
  $options = array_flip($options);

  if (!empty($default_options)) {
    $options = array_merge($default_options, $options);
  }

  return $options;
}

/**
 * @param $tree - список терминов словаря
 * @param $parent_term - термин, для которого определить значение (имя или массив с наследниками)
 * @param $tids_include_only - отсутствующие в этом списке термины исключить из вывода
 * @return array
 *
 * получить опции в иерархическом порядке
 * вида:
 *   $options = [
 *    '11' => 'Родитель',
 *    '15' => '-Потомок',
 *    '15' => '--Потомок 2',
 *    '15' => '--Потомок 2',
 *    '16' => '-Потомок',
 *    '17' => '-Потомок',
 *    '11' => 'Родитель',
 *  ];
 *
 */
function dash_select_tree_get($tree, $parent_term = null, $tids_include_only = [])
{
  $option = false;
  $child = [];
  $tid = $parent_term->tid ?? 0;
  foreach($tree as $term) {
    if (in_array($tid, $term->parents)) {
      if ($result = dash_select_tree_get($tree, $term, $tids_include_only)) {
        $child += $result;
      }
    }
  }
  if ($child) {
    if ($tid) {
      $option[$tid] = str_repeat("-", $parent_term->depth) . $parent_term->name;
      $option += $child;
    }  else {
      $option = $child;
    }
  } else {
    if ($parent_term->name) {
      if (!$tids_include_only || in_array($tid, $tids_include_only)) $option[$tid] = str_repeat("-", $parent_term->depth) . $parent_term->name;
    }
  }

  return $option;
}

/**
 * Создать Запись плана типа cash_income
 */
function dash_cash_income_create($params)
{
  $transaction = db_transaction();
  try {
    $ci = entity_create('cash_income', [
      'type' => 'cash_income',
      'created' => $params['created'],
    ]);
    entity_save('cash_income', $ci);

    $ci_wr = entity_metadata_wrapper('cash_income', $ci);
    $ci_wr->field_ci_company = $params['company_id'];
    $ci_wr->field_ci_date = $params['month_ts'];
    $ci_wr->field_ci_type = $params['type'];
    $ci_wr->field_ci_is_manual = $params['manual'] ?? 0;
    $ci_wr->field_ci_amount = $params['amount'] ?? 0;
    $ci_wr->save();
  } catch (Exception $e) {
    $transaction->rollback();
    watchdog_exception('migration', $e);
  }

  return $ci ?? false;
}

