/**
 *  Вернуть данные по Кредитам и задолженностям (сущность debt/debt)
 *  с учётом заданных параметров
 * @param $conditions
 *   - company_id* - tid компании
 *   - period - массив ['from' =>, 'to' => не включительно] * - обязателен
 *   - type - тип записи (1 - план, 2 - факт)
 *   - kinds - массив типов записей (1 - дебиторская, 2- кредиторская, 3 - кредиты, 4 - займы)
 *   - category - категория записи (пока это 1 - статья, 2 - контрагент)
 *   - manual - данные из 1с или ручной ввод (если не задано, то только данные из 1с)
 * @return array|mixed|null
 */
function dash_debt_get_by_conditions($conditions)
{
  $fid = drupal_hash_base64(__FUNCTION__ . serialize($conditions));
  $result = &drupal_static($fid);

  if (!isset($result)) {
    $dbr = db_select('eck_debt', 'd');
    $dbr->condition('d.type', 'debt');
    $dbr->addField('d', 'id');

    $dbr->innerJoin('field_data_field_d_company', 'fc', 'fc.entity_id = d.id');
    $dbr->condition('fc.field_d_company_tid', $conditions['company_id']);
    $dbr->addField('fc', 'field_d_company_tid', 'company');

    $dbr->innerJoin('field_data_field_d_name', 'fn', 'fn.entity_id = d.id');
    $dbr->addField('fn', 'field_d_name_value', 'name');

    $dbr->innerJoin('field_data_field_d_category', 'fct', 'fct.entity_id = d.id');
    if (!empty($conditions['category'])) {
      $dbr->condition('fct.field_d_category_value', $conditions['category']);
    }
    $dbr->addField('fct', 'field_d_category_value', 'category');

    $dbr->innerJoin('field_data_field_d_type', 'ft', 'ft.entity_id = d.id');
    if (!empty($conditions['type'])) {
      $dbr->condition('ft.field_d_type_value', $conditions['type']);
    }
    $dbr->addField('ft', 'field_d_type_value', 'type');

    $dbr->innerJoin('field_data_field_d_kind', 'fk', 'fk.entity_id = d.id');
    if (!empty($conditions['kinds'])) {
      $dbr->condition('fk.field_d_kind_value', $conditions['kinds'], 'IN');
    }
    $dbr->addField('fk', 'field_d_kind_value', 'kind');

    $dbr->innerJoin('field_data_field_d_date', 'fd', 'fd.entity_id = d.id');
    $dbr->condition('fd.field_d_date_value', $conditions['period']['from'], '>=');
    $dbr->condition('fd.field_d_date_value', $conditions['period']['to'], '<');
    $dbr->addField('fd', 'field_d_date_value', 'date');

    $dbr->innerJoin('field_data_field_d_amount', 'fa', 'fa.entity_id = d.id');
    $dbr->addField('fa', 'field_d_amount_value', 'amount');

    $dbr->innerJoin('field_data_field_d_amount2', 'fa2', 'fa2.entity_id = d.id');
    $dbr->addField('fa2', 'field_d_amount2_value', 'amount2');

    $dbr->innerJoin('field_data_field_d_is_manual', 'fm', 'fm.entity_id = d.id');
    if (empty($conditions['manual'])) {
      $dbr->condition('fm.field_d_is_manual_value', 0);
    } else {
      $dbr->condition('fm.field_d_is_manual_value', 1);
    }
    $dbr->addField('fm', 'field_d_is_manual_value', 'manual');

    $dbr->orderBy('date');
    $result = $dbr->execute()->fetchAll();
  }

  return $result;
}


/**
 *  Вернуть данные по из таблицы Бюджета доходов и расходов (ручной ввод данных) (manual/bdr)
 *  с учётом заданных параметров
 * @param $conditions
 *   - company_id* - tid компании
 *   - period* - массив ['from' =>, 'to' => не включительно]
 *   - type - тип записи (план, факт, неотгруженные контракты)
 *   - category_id - статья Бюджета доходов и расходов
 * @return array|mixed|null
 */
function dash_manual_bdr_get_by_conditions($conditions)
{
  $fid = drupal_hash_base64(__FUNCTION__ . serialize($conditions));
  $result = &drupal_static($fid);

  if (!isset($result)) {
    $dbr = db_select('eck_manual', 'm');
    $dbr->condition('m.type', 'bdr');
    $dbr->addField('m', 'id');

    $dbr->innerJoin('field_data_field_m_company', 'fc', 'fc.entity_id = m.id');
    $dbr->condition('fc.bundle', 'bdr');
    $dbr->condition('fc.field_m_company_tid', $conditions['company_id']);
    $dbr->addField('fc', 'field_m_company_tid', 'company');

    $dbr->innerJoin('field_data_field_m_date', 'frd', 'frd.entity_id = m.id');
    $dbr->condition('frd.bundle', 'bdr');
    $dbr->condition('frd.field_m_date_value', $conditions['period']['from'], '>=');
    $dbr->condition('frd.field_m_date_value', $conditions['period']['to'], '<');
    $dbr->addField('frd', 'field_m_date_value', 'date');

    $dbr->innerJoin('field_data_field_m_type', 'frt', 'frt.entity_id = m.id');
    $dbr->condition('frt.bundle', 'bdr');
    if (isset($conditions['type'])) {
      $dbr->condition('frt.field_m_type_value', $conditions['type']);
    }
    $dbr->addField('frt', 'field_m_type_value', 'type');

    $dbr->innerJoin('field_data_field_m_category', 'fct', 'fct.entity_id = m.id');
    $dbr->condition('fct.bundle', 'bdr');
    if (isset($conditions['category_id'])) {
      $dbr->condition('fct.field_m_category_tid', $conditions['category_id']);
    }
    $dbr->innerJoin('taxonomy_term_data', 'tc', 'tc.tid = fct.field_m_category_tid');
    $dbr->addField('tc', 'tid', 'category_id');
    $dbr->addField('tc', 'name', 'category_name');

    $dbr->innerJoin('field_data_field_m_amount', 'fa', 'fa.entity_id = m.id');
    $dbr->condition('fa.bundle', 'bdr');
    $dbr->addField('fa', 'field_m_amount_value', 'amount');

    $dbr->orderBy('date');
    $result = $dbr->execute()->fetchAll();
  }

  return $result;
}

/**
 * ----- Формы ---------------------------------------------------------------------------------------------------------
 */
function dash_period_filter_form($form, &$form_state, $params)
{
  if (!isset($form_state['period'])) {
    $form_state['period'] = $params['period'];
  }
  $form_state['callback'] = $params['callback'];

  $form['#attributes'] = ['class' => ['dash-filter-form']];
  $form['period'] = [
    '#type' => 'container',
    '#attributes' => ['class' => ['period-container']],
  ];
  $form['period']['period_from'] = [
    '#type' => 'date_popup',
    '#title' => 'Период',
    '#default_value' => date('Y-m-d', empty($_GET['period_from']) ? $form_state['period']['from'] : $_GET['period_from']),
    '#ajax' => [
      'wrapper' => $params['wrapper'],
      'callback' => 'dash_period_filter_form_ajax_callback',
    ],
    '#date_format' => 'd.m.Y',
    '#date_year_range' => '-3:+1',
    '#date_label_position' => 'invisible',
  ];

  $form['period']['period_to'] = [
    '#type' => 'date_popup',
    '#title' => '&nbsp;',
    '#default_value' => date('Y-m-d', empty($_GET['period_to']) ? $form_state['period']['to'] - 1 : $_GET['period_to']),
    '#ajax' => [
      'wrapper' => $params['wrapper'],
      'callback' => 'dash_period_filter_form_ajax_callback',
    ],
    '#date_format' => 'd.m.Y',
    '#date_year_range' => '-3:+1',
    '#date_label_position' => 'invisible',
  ];

  return $form;
}
function dash_period_filter_form_ajax_callback($form, $form_state)
{
  $period = [
    'from' => strtotime($form_state['values']['period_from']['date']),
    'to' => strtotime($form_state['values']['period_to']['date']) + 60*60*24,  // конец периода задаётся днём, следующим за заданным
    'end' => '',
  ];

  // todo небезопасно
  $func = $form_state['callback'];

  return (function_exists($func) ? $func($period) : 'Function ' . $func . ' not found');
}

/**
 * ----- Вспомогательные функции ---------------------------------------------------------------------------------------
 */

/** Вернуть начальное и конечное (не включительно) время Unix
 * 12-и месячного периода начиная с месяца $month_num
 * и смещением $year_shift лет от текущего периода.
 * from - начало 12и месячного периода
 * to   - == end для прошлых периодов и == now для текущего
 * end  - конец 12и месячного периода
 * $year_shift = 0 - текущий период
 */
function dash_year_time_bounds_get($month_num_start, $year_shift = 0)
{
  // получить начало текущего периода
  $time_month_start = gmmktime(0, 0, 0, $month_num_start, 1, date('Y'));
  $year_start = REQUEST_TIME < $time_month_start ? date('Y')-1 : date('Y');

  // применить смещение
  $year_start = $year_start + $year_shift;

  $from = gmmktime(0, 0, 0, $month_num_start, 1, $year_start);
  $end = gmmktime(0, 0, 0, $month_num_start+12, 1, $year_start);
  // для предыдущих берем весь сезон
  if ($year_shift) {
    $to = gmmktime(0, 0, 0, $month_num_start+12, 1, $year_start);
  }
  // для текущего по сегодняшнюю дату
  else {
    $to = gmmktime(0, 0, 0, date('n'), date('j'), date('Y'));
  }

  return [
    'from' => $from,
    'to' => $to,
    'end' => $end,
  ];
}

/**
 * Вернуть начальное и конечное (не включительно) время Unix
 * 12-и месячного Сезона начиная с месяца $month_num_start.
 *
 * Сезон определяется НА ЗАДАННЫЙ МЕСЯЦ.
 * То есть, для сезона, начинающегося в Октябре ($month_num_start = 10),
 * если дата $datetime_set задана в октябре, то данные выводим по сентябрь включительно, то есть предыдущий сезон.
 * Если дата в ноябре, то это данные за октябрь, а октябрь - начало нового сезона.
 *
 * @return
 *   from - начало 12и месячного периода
 *   to   - == end для прошлых периодов и == now для текущего
 *   end  - конец 12и месячного периода
 */
function dash_season_bounds_get_by_date($month_num_start, $datetime_set)
{
  // получить начало заданного месяца
  $month_start_set = gmmktime(0, 0, 0, date('n', $datetime_set), 1, date('Y', $datetime_set));

  // год заданного месяца
  $year = date('Y', $month_start_set);

  // ищем Сезон, включающий заданный месяц
  // сравниваем с предыдущим месяцем ($month_start_set-1), так как заданный месяц определяет
  do {
    $period_from_month_start = gmmktime(0, 0, 0, $month_num_start, 1, $year);
    $period_end_month_start = gmmktime(0, 0, 0, $month_num_start + 12, 1, $year);
    $year--;
  } while (!($period_from_month_start <= ($month_start_set-1) && ($month_start_set-1) < $period_end_month_start));

  return [
    'from' => $period_from_month_start,
    'to' => $month_start_set,
    'end' => $period_end_month_start,
  ];
}

/**
 * Вернуть начальное и конечное (не включительно) время Unix
 * для периода:
 *   с месяца $month_num и смещением $year_shift (0 - текущий) лет от текущего периода
 *   до текущей даты в заданном сезоне
 *
 * from - начало 12и месячного периода
 * to   - == end для прошлых периодов и == now для текущего
 */
function dash_period_time_bounds_get($month_num_start, $year_shift = 0)
{
  // получить начало текущего периода
  $time_month_start = gmmktime(0, 0, 0, $month_num_start, 1, date('Y'));
  $year_start = REQUEST_TIME < $time_month_start ? date('Y')-1 : date('Y');

  // применить смещение
  $year_start = $year_start + $year_shift;

  $from = gmmktime(0, 0, 0, $month_num_start, 1, $year_start);
  $to = gmmktime(0, 0, 0, date('n'), date('j'), date('Y') + $year_shift);

  return [
    'from' => $from,
    'to' => $to,
  ];
}

/**
 * Вернуть смещение заданного периода на заданное количество лет
 */
function dash_period_shifted_get($period, $year_shift = 0)
{
  $from = gmmktime(0, 0, 0, date('n', $period['from']), date('j', $period['from']), date('Y', $period['from']) + $year_shift);
  $to = gmmktime(0, 0, 0, date('n', $period['to']), date('j', $period['to']), date('Y', $period['to']) + $year_shift);
  $end = gmmktime(0, 0, 0, date('n', $period['end']), date('j', $period['end']), date('Y', $period['end']) + $year_shift);

  return [
    'from' => $from,
    'to' => $to,
    'end' => $end,
  ];
}

/**
 * Вернуть для страницы период по-умолчанию
 * @param $month_start
 * @return array
 */
function dash_page_time_bounds_get($month_start)
{
  if (strpos($_GET['q'], 'period/closed') !== false) {
    $bounds = dash_year_time_bounds_get($month_start, -1);
  } else {
    $bounds = dash_year_time_bounds_get($month_start);
  }

  return $bounds;
}

