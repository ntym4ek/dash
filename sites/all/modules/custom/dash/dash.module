/**
 * Возвращает список месяцев (unix начало и конец) для Периода на входе
 * @param $period
 * @return array
 */
function dash_months_list_get($period)
{
  // список месяцев, за которые выводим график
  $time_months_list = [];
  $time_month_start = $period['from'];
  while($time_month_start < $period['end']) {
    $time_month_end = gmmktime(0, 0, 0, date('n', $time_month_start)+1, 1, date('Y', $time_month_start));
    $time_months_list[] = [
      'start' => $time_month_start,
      'end' => $time_month_end,
    ];
    $time_month_start = $time_month_end;
  }

  return $time_months_list;
}

/**
 * Возвращает список недель (unix начало и конец) для Периода на входе
 * @param $period
 * @return array
 */
function dash_weeks_list_get($period)
{
  $time_weeks_list = [];

  // начальная неделя + 2 дня (начало нашей недели в среду)
  $week_num = date('W', $period['from']);
  $year = date('Y', $period['from']);
  $week_start =  gmmktime(0,0,0,1,1, $year) + $week_num * 7 * 86400 - date('N', gmmktime(0,0,0,1,1,$year)) * 86400 + 3*86400;

  // далее список +7 дней
  while($week_start < $period['end']) {
    $week_end =  $week_start + 7 * 86400;
    if ($week_start < $period['from']) $week_start = $period['from'];
    if ($week_end > $period['end']) $week_end = $period['end'];

    $time_weeks_list[] = [
      'start' => $week_start,
      'end' => $week_end,
    ];
    $week_start = $week_end;
  }

  return $time_weeks_list;
}

/**
 * Возвращает потомков термина на входе
 * @param $parent_tid
 * @return array
 */
function dash_term_siblings_get($parent_tid)
{
  $result = [$parent_tid];

  if ($parent_term = taxonomy_term_load($parent_tid)) {
    foreach (taxonomy_get_tree($parent_term->vid, $parent_tid) as $terms) {
      $result[] = $terms->tid;
    }
  }

  return $result;
}

/**
 * Ищет и возвращает запись по 1с ID из справочника $vid.
 * Создаёт и возвращает пустую новую, если запись не найдена.
 * @param $voc - vid словаря или его наименование
 * @param $record_1c_id
 * @return false|object
 */
function dash_term_get_by_1c_id($voc, $record_1c_id)
{
  $vid = is_numeric($voc) ? $voc : taxonomy_vocabulary_machine_name_load($voc)->vid;

  if ($vid && $record_1c_id) {
    $query = new EntityFieldQuery();
    $terms = $query
      ->entityCondition('entity_type', 'taxonomy_term')
      ->propertyCondition('vid', $vid)
      ->fieldCondition('field_1c_id', 'value', $record_1c_id)
      ->execute();
    if ($terms) {
      $term = current($terms['taxonomy_term']);
    } else {
      $term = (object)array(
        'vid' => $vid,
        'name' => '',
        'field_1c_id' => ['und' => [0 => ['value' => $record_1c_id]]],
      );
      taxonomy_term_save($term);
    }
    $entities = entity_load('taxonomy_term', [$term->tid]);
  }
  return empty($entities) ? false: current($entities);
}

function dash_nomenklatura_get_by_1c_artikul($company_inn, $artikul)
{
  // номенклатура хранится в разных словарях
  $vid = taxonomy_vocabulary_machine_name_load('nomenklatura')->vid;
  $company = dash_term_get_by_1c_id('companies', $company_inn);
  if ($vid && $artikul) {
    $query = new EntityFieldQuery();
    $query
      ->entityCondition('entity_type', 'taxonomy_term')
      ->propertyCondition('vid', $vid)
      ->fieldCondition('field_nom_artikul', 'value', $artikul);
    $query->fieldCondition('field_kccc_company', 'tid', $company->tid);
    $terms = $query->execute();
    if ($terms) {
      $term = current($terms['taxonomy_term']);
      $entities = $term ? entity_load('taxonomy_term', [$term->tid]) : null;
    }
  }
  return empty($entities) ? 0 : current($entities);
}

/**
 * Найти клиента по 1c_id или создать, если не найден

 * @param $company_inn - справочник какой компании KCCC проверять
 * @param $client_id
 * @return false|int|mixed
 */
function dash_client_get_by_1c_id($company_inn, $client_id)
{
  // клиенты хранятся в разных словарях
  $vid = taxonomy_vocabulary_machine_name_load('clients')->vid;
  $company = dash_term_get_by_1c_id('companies', $company_inn);

  if ($vid && $client_id) {
    $query = new EntityFieldQuery();
    $query->entityCondition('entity_type', 'taxonomy_term')
      ->propertyCondition('vid', $vid)
      ->fieldCondition('field_1c_id', 'value', $client_id);
    $query->fieldCondition('field_kccc_company', 'tid', $company->tid);
    $terms = $query->execute();
    if ($terms) {
      $term = current($terms['taxonomy_term']);
    } else {
      $term = (object)array(
        'vid' => $vid,
        'name' => '',
        'field_1c_id' => ['und' => [0 => ['value' => $client_id]]],
        'field_kccc_company' => ['und' => [0 => ['tid' => $company->tid]]],
      );
      taxonomy_term_save($term);
    }
    $entities = $term ? entity_load('taxonomy_term', [$term->tid]) : null;
  }
  return empty($entities) ? 0: current($entities);
}

