function ext_admin_database_process_record_3($record_id)
{
  // обработать запись базы данных
  $arr = [];
  $remains_wr = entity_metadata_wrapper('remains', $record_id);
  $arr['nom'] = $remains_wr->field_nomenklatura_td->value();
  $arr['wh'] = $remains_wr->field_warehouse_td->value();
  $arr['qty'] = $remains_wr->field_quantity_td->value();
  $arr['price'] = $remains_wr->field_price->value();
  $arr['date'] = $remains_wr->field_date->value();
  $arr['date_exp'] = $remains_wr->field_date_expiration->value();

    $remains = entity_create('remains', [
      'type' => 'remains',
    ]);
    entity_save('remains', $remains);
    entity_delete('remains', $record_id);

    $new_wr = entity_metadata_wrapper('remains', $remains);
    $new_wr->field_rm_nomenklatura = $arr['nom'];
    $new_wr->field_rm_warehouse = $arr['wh'];
    $new_wr->field_rm_quantity = $arr['qty'];
    $new_wr->field_rm_price = $arr['price'];
    $new_wr->field_rm_date = $arr['date'];
    $new_wr->field_rm_date_exp = $arr['date_exp'];
    $new_wr->save();

  watchdog('message', 'Обработана запись с id: ' . $record_id);
}


function ext_admin_queue_database_processing_4()
{
  // получить записи с незаполненным полем и поставить в очередь
  $q = db_select('eck_plan', 'p');
  $q->condition('p.type', 'plan_ship');
  $q->fields('p', array('id'));

  if ($items = $q->execute()->fetchCol()) {
    $queue = DrupalQueue::get('database_processing_queue_4');
    $queue->deleteQueue();

    foreach($items as $item) {
      $queue->createItem($item);
    }

    drupal_set_message('Записей, помещённых в очередь: ' . count($items) . ' (' . $items[0] . ' - ' . array_pop($items) . ')');
    return true;
  }
}

function ext_admin_database_process_record_4($record_id)
{
  // обработать запись базы данных
  $arr = [];
  $plan_wr = entity_metadata_wrapper('plan', $record_id);
  if ($plan_wr->value()) {
    $arr['type'] = $plan_wr->field_record_type_td->value();
    $arr['client'] = $plan_wr->field_client->value();
    $arr['qty'] = $plan_wr->field_quantity_td->value();
    $arr['date'] = $plan_wr->field_date->value();
    $arr['amount'] = $plan_wr->field_amount->value();
    $arr['net_cost'] = $plan_wr->field_net_cost->value();
    $arr['manual'] = $plan_wr->field_is_manual->value();
    $arr['created'] = $plan_wr->created->value();
    $arr['nom'] = $plan_wr->field_nomenklatura->value();

    if ($arr['type'] && $arr['date']) {
      $ship = entity_create('ship', [
        'type' => 'ship',
        'created' => $arr['created'],
      ]);
      entity_save('ship', $ship);

      $new_wr = entity_metadata_wrapper('ship', $ship);
      $new_wr->field_s_company = 196472; // тд
      $new_wr->field_s_date = $arr['date'];
      $new_wr->field_s_type = $arr['type'] + 1;
      $new_wr->field_s_amount = $arr['amount'];
      $new_wr->field_s_quantity = $arr['qty'];
      $new_wr->field_s_net_cost = $arr['net_cost'];
      $new_wr->field_s_is_manual = $arr['manual'] ?? 0;
      $new_wr->field_s_nomenklatura = $arr['nom'];
      $new_wr->field_s_client = $arr['client'];
      $new_wr->save();
    }
  }

  entity_delete('plan', $record_id);

  watchdog('message', 'Обработана запись с id: ' . $record_id);
}

function ext_admin_queue_database_processing_5()
{
  $dbr = db_select('taxonomy_term_data', 't');
  $dbr->condition('t.vid', taxonomy_vocabulary_machine_name_load('nomenklatura_td')->vid);
  $dbr->addField('t', 'tid');
  if ($tids = $dbr->execute()->fetchCol()) {

    $queue = DrupalQueue::get('database_processing_queue_5');
    $queue->deleteQueue();

    foreach($tids as $tid) {
      $queue->createItem($tid);
    }

    drupal_set_message('Записей, помещённых в очередь: ' . count($tids));
  }
}

function ext_admin_database_process_record_5($record_id)
{
  $arr = [];
  $term_wr = entity_metadata_wrapper('taxonomy_term', $record_id);
  $arr['name'] = $term_wr->label();
  $arr['id1c'] = $term_wr->field_1c_id->value();
  $arr['art'] = $term_wr->field_nom_artikul->value();
  $arr['unit'] = $term_wr->field_nom_unit->value();
  $arr['nds'] = $term_wr->field_nom_nds->value();
  $arr['status'] = $term_wr->field_status->value();

  $vid = taxonomy_vocabulary_machine_name_load('nomenklatura')->vid;
  $new_term = (object)array(
    'vid' => $vid,
    'name' => $arr['name'],
    'field_1c_id' => ['und' => [0 => ['value' => $arr['id1c']]]],
    'field_kccc_company' => ['und' => [0 => ['tid' => 196472]]], // тд
  );
  taxonomy_term_save($new_term);

  $new_wr = entity_metadata_wrapper('taxonomy_term', $new_term);
  $new_wr->field_status = $arr['status'];
  $new_wr->field_nom_artikul = $arr['art'];
  $new_wr->field_nom_unit = $arr['unit'];
  $new_wr->field_nom_nds = $arr['nds'];
  $new_wr->save();

  $q = db_select('eck_plan', 'p');
  $q->condition('p.type', 'plan_ship');
  $q->innerjoin('field_data_field_nomenklatura_td', 'fc', 'fc.entity_id = p.id');
  $q->condition('fc.field_nomenklatura_td_tid', $record_id);
  $q->fields('p', array('id'));
  if ($items = $q->execute()->fetchCol()) {
    foreach ($items as $item) {
      $wr = entity_metadata_wrapper('plan', $item);
      $wr->field_nomenklatura = $new_term->tid;
      $wr->save();
    }
  }

  $q = db_select('eck_analog_price', 'p');
  $q->innerjoin('field_data_field_ap_nom_td', 'fc', 'fc.entity_id = p.id');
  $q->condition('fc.field_ap_nom_td_tid', $record_id);
  $q->fields('p', array('id'));
  if ($items = $q->execute()->fetchCol()) {
    foreach ($items as $item) {
      $wr = entity_metadata_wrapper('analog_price', $item);
      $wr->field_ap_nomenklatura = $new_term->tid;
      $wr->save();
    }
  }

  $q = db_select('eck_registration', 'r');
  $q->innerjoin('field_data_field_nomenklaturas_td', 'fc', 'fc.entity_id = r.id');
  $q->condition('fc.field_nomenklaturas_td_tid', $record_id);
  $q->fields('r', array('id'));
  if ($items = $q->execute()->fetchCol()) {
    foreach ($items as $item) {
      $wr = entity_metadata_wrapper('registration', $item);
      $wr->field_r_nomenklaturas[] = $new_term->tid;
      $wr->save();
    }
  }

  watchdog('message', 'Обработана запись с id: ' . $record_id);
}

