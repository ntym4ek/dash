function ext_admin_database_process_record($term_id)
{
  $company = dash_term_get_by_1c_id('companies', DASH_INN_AH);
  $term_wr = entity_metadata_wrapper('taxonomy_term', $term_id);
  $term_wr->field_1c_id = $term_wr->field_client_id->value();
  $term_wr->field_kccc_company = $company->tid;
  $term_wr->save();
}

function ext_admin_queue_database_processing_2()
{
  // получить записи с незаполненным полем и поставить в очередь
  $q = db_select('eck_revenue', 'r');
  $q->fields('r', array('id'));

  if ($items = $q->execute()->fetchCol()) {
    $queue = DrupalQueue::get('database_processing_queue_2');
    $q->leftjoin('field_data_field_revenue_company', 'frc', 'frc.entity_id = r.id');
    $q->isNull('frc.field_revenue_company_value');

//    $queue->deleteQueue();

    foreach($items as $item) {
      $queue->createItem($item);
    }

    drupal_set_message('Записей, помещённых в очередь: ' . count($items));
    return true;
  }
}

