/**
 * Implementation of hook_menu().
 */
function dep_2v_2g_menu()
{
  $items['td/department-2v-2g'] = array(
    'title' => 'Управления 2В и 2Г',
    'menu_name' => 'main-menu',
    'weight' => 2,
    'page callback' => 'dep_2v_2g_current_page',
    'access callback' => 'ext_user_has_roles',
    'access arguments' => [[ADMIN_RID, TRADE_HOUSE_USER_RID]],
    'type' => MENU_NORMAL_ITEM,
  );
  $items['td/department-2v-2g/current'] = array(
    'title' => 'Текущий период',
    'type' => MENU_DEFAULT_LOCAL_TASK,
    'weight' => 10,
  );
  $items['td/department-2v-2g/closed'] = array(
    'title' => 'Завершившийся период',
    'page callback' => 'dep_2v_2g_current_page',
    'page arguments' => [true],
    'access callback' => 'ext_user_has_roles',
    'access arguments' => [[ADMIN_RID, TRADE_HOUSE_USER_RID]],
    'type' => MENU_LOCAL_TASK,
    'weight' => 1,
  );
  $items['td/department-2v-2g/previous'] = array(
    'title' => 'Предыдущий период',
    'page callback' => 'dep_2v_2g_previous_page',
    'access callback' => 'ext_user_has_roles',
    'access arguments' => [[ADMIN_RID, TRADE_HOUSE_USER_RID]],
    'type' => MENU_LOCAL_TASK,
    'weight' => 0,
  );

  return $items;
}

