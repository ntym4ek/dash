    $form['intro'] = ['#markup' => '<div class="intro">' . $intro . '</div>'];

    return $form;
  }

  $intro = '<p>Форма позволяет добавлять новые и&nbsp;редактировать ранее введённые данные</p>';
  $form['intro'] = [
    '#markup' => '<div class="intro">' . $intro . '</div>',
    '#attached' => ['js' => [[
      'data' => ['messages' => ['position' => 'inline']],
      'type' => 'setting',
    ]]],
  ];

  $options_m = [0 => ' - Месяц - '];
  for($i = 1; $i <= 12; $i++) {
    $options_m[$i] = helper_month_label_ru($i);
  }
  $form['month']['month'] = [
    '#type' => 'select',
    '#options' => $options_m,
    '#default_value' => 0,
    '#prefix' => '<div class="row"><div class="col-xs-7 col-md-5">',
    '#suffix' => '</div>',
    '#ajax' => [
      'callback' => 'reports_debt_data_edit_form_callback',
      'wrapper' => 'data-debt-edit-wrapper',
    ],
  ];

  $options_y = [0 => ' - Год - '];
  for($i = DASH_HISTORY_START_YEAR_TD; $i <= date('Y'); $i++) {
    $options_y[$i] = $i;
  }
  $form['month']['year'] = [
    '#type' => 'select',
    '#options' => $options_y,
    '#default_value' => 0,
    '#prefix' => '<div class="col-xs-5 col-md-4">',
    '#suffix' => '</div>',
    '#ajax' => [
      'callback' => 'reports_debt_data_edit_form_callback',
      'wrapper' => 'data-debt-edit-wrapper',
    ],
  ];

  $form['type'] = [
    '#type' => 'select',
    '#options' => [DASH_TYPE_PLAN => 'План'],
    '#prefix' => '<div class="col-xs-12 col-md-3">',
    '#suffix' => '</div>',
    '#ajax' => [
      'callback' => 'reports_debt_data_edit_form_callback',
      'wrapper' => 'data-debt-edit-wrapper',
    ],
  ];

  $form['kind'] = [
    '#type' => 'select',
    '#title' => 'Вид задолженности',
    '#options' => [DASH_DEBT_KIND_CREDIT => 'Внешние кредиты'],
    '#prefix' => '<div class="col-xs-6">',
    '#suffix' => '</div>',
    '#ajax' => [
      'callback' => 'reports_debt_data_edit_form_callback',
      'wrapper' => 'data-debt-edit-wrapper',
    ],
  ];

  // если изменены месяц/год, определить наличие данных
  $is_month_selected = false;
  $record_id = 0;
  if (isset($form_state['triggering_element']['#name']) && in_array($form_state['triggering_element']['#name'], ['month', 'year', 'type', 'kind'])) {
    $amount_default = 0;
    if ($form_state['values']['month'] && $form_state['values']['year']) $is_month_selected = true;

    if ($is_month_selected) {
      $period = [
        'from' => gmmktime(0, 0, 0, (int)$form_state['values']['month'], 1, (int)$form_state['values']['year']),
        'to' => gmmktime(0, 0, 0, (int)$form_state['values']['month']+1, 1, (int)$form_state['values']['year']),
      ];
      if ($data = dash_debt_get_by_conditions([
        'company_id' => $company_id, 'period' => $period, 'manual' => 1,
        'type' => $form_state['values']['type'], 'kinds' => [$form_state['values']['kind']]
      ])) {
        $record = reset($data);
        $amount_default = $record->amount;
        $record_id = $record->id;
      }
    }
    $form_state['input']['amount'] = $amount_default;
    $form_state['values']['amount'] = $amount_default;
  }

  // id записи, если найдена существующая
  $form['record'] = [
    '#type' => 'hidden',
    '#value' => $record_id,
  ];
  // от какой компании создаётся запись
  $form['company_id'] = [
    '#type' => 'hidden',
    '#value' => $company_id,
  ];

  $form['amount'] = [
    '#type' => 'textfield',
    '#size' => 20,
    '#title' => 'Сумма (руб.)',
    '#required' => true,
    '#default_value' => 0,
    '#disabled' => !$is_month_selected,
    '#prefix' => '<div class="col-xs-6">',
    '#suffix' => '</div></div>',
  ];

  $form['actions'] = ['#type' => 'actions'];
  $form['actions']['submit'] = [
    '#type' => 'submit',
    '#value' => 'Отправить',
    '#attributes' => ['class' => ['btn-primary', 'btn-wide']],
    '#disabled' => !$is_month_selected,
    '#ajax' => [
      'callback' => 'reports_debt_data_edit_form_callback',
      'wrapper' => 'data-debt-edit-wrapper',
    ],
  ];

  return $form;
}
function reports_debt_data_edit_form_callback($form, $form_state)
{
  return $form;
}
function reports_debt_data_edit_form_submit($form, $form_state)
{
  $month_start = gmmktime(0, 0, 0, (int)$form_state['values']['month'], 1, (int)$form_state['values']['year']);

  // удалить старые записи за месяц
  if ($form_state['values']['record']) {
    entity_delete('debt', $form_state['values']['record']);
  }

  // добавить Запись плана
  $record = dash_debt_create([
    'created' => REQUEST_TIME,
    'company_id' => $form_state['values']['company_id'],
    'month_ts' => $month_start,
    'type' => $form_state['values']['type'],
    'kind' => $form_state['values']['kind'],
    'manual' => 1,
    'amount' => $form_state['values']['amount'],
  ]);

  // обновление блоков
  if (!empty($form_state['blocks'])) {
    foreach ($form_state['blocks'] as $block) {
      $block = check_plain($block);
      $output = '<div class="ajax-load" data-func="' . $block . '"><div class="ajax-progress ajax-progress-throbber"><div class="throbber">&nbsp;</div><div class="message">Пожалуйста, подождите...</div></div></div>';
      $commands[] = ajax_command_replace('[data-func="' . $block . '"]', $output);
    }
  }

  $commands[] = ajax_command_invoke('.autodialog-content', 'dialog', array('close'));
  ctools_include('ajax');
  ctools_add_js('ajax-responder');
  print ajax_render($commands);
  drupal_exit();
}

