  drupal_exit();
}

function reports_debt_data_edit_form($form, &$form_state)
{
  // сохраняем блоки, которые нужно обновить
  if (!empty($_GET["blocks"])) {
    $form_state['blocks'] = $_GET["blocks"];
  }

  // определяем ID компании, для которой заполняется форма
  $company_id = 0;
  if (empty($form_state["values"]['company_id'])) {
    if (isset($_GET["inn"])) {
      $company = dash_term_get_by_1c_id('companies', $_GET["inn"]);
      $company_id = $company->tid;
    }
  } else $company_id = $form_state["values"]['company_id'];

  $form = [
    '#prefix' => '<div id="data-debt-edit-wrapper" class="data-debt-edit-wrapper">',
    '#suffix' => '</div>',
  ];

  if (empty($company_id)) {
    $intro = '<p>Не задан идентификатор компании. Обратитесь к администратору сайта.</p>';
    $form['intro'] = ['#markup' => '<div class="intro">' . $intro . '</div>'];

    return $form;
  }

  $intro = '<p>Форма позволяет добавлять новые и&nbsp;редактировать ранее введённые данные</p>';
  $form['intro'] = [
    '#markup' => '<div class="intro">' . $intro . '</div>',
    '#attached' => ['js' => [[
      'data' => ['messages' => ['position' => 'inline']],
      'type' => 'setting',
    ]]],
  ];

  $options_y = [0 => ' - Год - '];
  for($i = DASH_HISTORY_START_YEAR_TD; $i <= date('Y'); $i++) {
    $options_y[$i] = $i;
  }
  $form['year'] = [
    '#type' => 'select',
    '#options' => $options_y,
    '#default_value' => 0,
    '#prefix' => '<div class="row"><div class="col-xs-6">',
    '#suffix' => '</div>',
    '#ajax' => [
      'callback' => 'reports_debt_data_edit_form_callback',
      'wrapper' => 'data-debt-edit-wrapper',
    ],
  ];

  $form['type'] = [
    '#type' => 'select',
    '#options' => [DASH_TYPE_PLAN => 'План'],
    '#prefix' => '<div class="col-xs-6">',
    '#suffix' => '</div>',
    '#ajax' => [
      'callback' => 'reports_debt_data_edit_form_callback',
      'wrapper' => 'data-debt-edit-wrapper',
    ],
  ];

  // вид долга Внешние кредиты
  $form['kind'] = [
    '#type' => 'hidden',
    '#value' => DASH_DEBT_KIND_CREDIT,
  ];

  // от какой компании создаётся запись
  $form['company_id'] = [
    '#type' => 'hidden',
    '#value' => $company_id,
  ];

  // если изменены месяц/год, определить наличие данных
  $amounts = [];
  $is_year_selected = false;
  if (isset($form_state['triggering_element']['#name']) && in_array($form_state['triggering_element']['#name'], ['year'])) {
    if ($form_state['values']['year']) $is_year_selected = true;

    if ($is_year_selected) {
      $period = [
        'from' => gmmktime(0, 0, 0, 1, 1, $form_state['values']['year']),
        'to' => gmmktime(0, 0, 0, 1, 1, $form_state['values']['year']+1),
      ];
      if ($data = dash_debt_get_by_conditions([
        'company_id' => $company_id, 'period' => $period, 'manual' => 1,
        'type' => $form_state['values']['type'], 'kinds' => [$form_state['values']['kind']]
      ])) {
        foreach ($data as $item) {
          $amounts[$item->date] = $item->amount;
        }
      }
    }
  }

  for($i = 1; $i <= 13; $i++) {
    $date_ts = $i < 13 ? gmmktime(0, 0, 0, $i, 1, $form_state['values']['year']) : gmmktime(0, 0, 0, 12, 31, $form_state['values']['year']);
    $form['amounts'][$i] = [
      '#type' => 'textfield',
      '#title' => $i < 13 ? helper_month_label_ru($i) : '31.12',
      '#default_value' => '',
      '#disabled' => !$is_year_selected,
      '#attributes' => ['class' => ['form-item-amount']],
      '#prefix' => '<div class="col-xs-6 col-md-4">',
      '#suffix' => '</div>' . ($i < 13 ? '' : '</div>'),
    ];
    $form_state['input'][$i] = (int)$amounts[$date_ts];
    $form_state['values'][$i] = (int)$amounts[$date_ts];
  }

  $form['actions'] = ['#type' => 'actions'];
  $form['actions']['submit'] = [
    '#type' => 'submit',
    '#value' => 'Отправить',
    '#attributes' => ['class' => ['btn-primary', 'btn-wide']],
    '#disabled' => !$is_year_selected,
    '#ajax' => [
      'callback' => 'reports_debt_data_edit_form_callback',
      'wrapper' => 'data-debt-edit-wrapper',
    ],
  ];

  return $form;
}
function reports_debt_data_edit_form_callback($form, $form_state)
{
  return $form;
}
function reports_debt_data_edit_form_submit($form, $form_state)
{
  // удалить старые записи за год типа ПЛАН введённые вручную
  $year_start = gmmktime(0, 0, 0, 1, 1, $form_state['values']['year']);
  $next_year_start = gmmktime(0, 0, 0, 1, 1, $form_state['values']['year']+1);

  $efquery = new EntityFieldQuery();
  $efquery
    ->entityCondition('entity_type', 'debt')
    ->entityCondition('bundle', 'debt')
    ->fieldCondition('field_d_company', 'tid', $form_state['values']['company_id'])
    ->fieldCondition('field_d_kind', 'value', $form_state['values']['kind'])
    ->fieldCondition('field_d_date', 'value', $year_start, '>=')
    ->fieldCondition('field_d_date', 'value', $next_year_start, '<')
    ->fieldCondition('field_d_is_manual', 'value', 1);

  $result = $efquery->execute();
  if ($result) {
    entity_delete_multiple('debt', array_keys($result['debt']));
  }

  // добавить новые Записи плана
  for($i = 1; $i <= 13; $i++) {
    $date_ts = $i < 13 ? gmmktime(0, 0, 0, $i, 1, $form_state['values']['year']) : gmmktime(0, 0, 0, 12, 31, $form_state['values']['year']);

    dash_debt_create([
      'created' => REQUEST_TIME,
      'company_id' => $form_state['values']['company_id'],
      'month_ts' => $date_ts,
      'type' => $form_state['values']['type'],
      'kind' => $form_state['values']['kind'],
      'manual' => 1,
      'amount' => $form_state['values'][$i],
    ]);
  }

  // обновление блоков
  if (!empty($form_state['blocks'])) {
    foreach ($form_state['blocks'] as $block) {
      $block = check_plain($block);
      $output = '<div class="ajax-load" data-func="' . $block . '"><div class="ajax-progress ajax-progress-throbber"><div class="throbber">&nbsp;</div><div class="message">Пожалуйста, подождите...</div></div></div>';
      $commands[] = ajax_command_replace('[data-func="' . $block . '"]', $output);
    }
  }

  $commands[] = ajax_command_invoke('.autodialog-content', 'dialog', array('close'));
  ctools_include('ajax');
  ctools_add_js('ajax-responder');
  print ajax_render($commands);
  drupal_exit();
}

function reports_ship_ship_data_edit_form($form, &$form_state)
{
  // сохраняем блоки, которые нужно обновить
  if (!empty($_GET["blocks"])) {
    $form_state['blocks'] = $_GET["blocks"];
  }

  // определяем ID компании, для которой заполняется форма
  if (empty($form_state["values"]['company_id'])) {
    $company_id = $_GET["inn"] ?? null;
    if (isset($company_id)) {
      $company = dash_term_get_by_1c_id('companies', $_GET["inn"]);
      $company_id = $company->tid;
    }
  } else $company_id = $form_state["values"]['company_id'];

  $form = [
    '#prefix' => '<div id="data-ship-edit-wrapper" class="data-ship-edit-wrapper">',
    '#suffix' => '</div>',
  ];

  // тип записей, которые доступны пользователю
  $type_available = $form_state["values"]["type_available"] ?? $_GET["type"] ?? 0;
  $form['type_available'] = [
    '#type' => 'hidden',
    '#value' => $type_available,
  ];

  if (empty($company_id)) {
    $intro = '<p>Не задан идентификатор компании. Обратитесь к администратору сайта.</p>';
    $form['intro'] = ['#markup' => '<div class="intro">' . $intro . '</div>'];

    return $form;
  }

  $intro = '<p>Форма позволяет добавлять новые и&nbsp;редактировать ранее введённые данные</p>';
  $form['intro'] = [
    '#markup' => '<div class="intro">' . $intro . '</div>',
    '#attached' => ['js' => [[
      'data' => ['messages' => ['position' => 'inline']],
      'type' => 'setting',
    ]]],
  ];

  $options_m = [0 => ' - Месяц - '];
  for($i = 1; $i <= 12; $i++) {
    $options_m[$i] = helper_month_label_ru($i);
  }
  $form['month']['month'] = [
    '#type' => 'select',
    '#options' => $options_m,
    '#default_value' => 0,
    '#prefix' => '<div class="row"><div class="col-xs-7 col-md-5">',
    '#suffix' => '</div>',
    '#ajax' => [
      'callback' => 'reports_ship_ship_data_edit_form_callback',
      'wrapper' => 'data-ship-edit-wrapper',
    ],
  ];

  $options_y = [0 => ' - Год - '];
  for($i = DASH_HISTORY_START_YEAR_TD; $i <= date('Y'); $i++) {
    $options_y[$i] = $i;
  }
  $form['month']['year'] = [
    '#type' => 'select',
    '#options' => $options_y,
    '#default_value' => 0,
    '#prefix' => '<div class="col-xs-5 col-md-4">',
    '#suffix' => '</div>',
    '#ajax' => [
      'callback' => 'reports_ship_ship_data_edit_form_callback',
      'wrapper' => 'data-ship-edit-wrapper',
    ],
  ];

  // где-то может быть доступно занесение только одного типа данных
  $options = [DASH_TYPE_PLAN => 'План', DASH_TYPE_FACT => 'Факт'];
  if ($type_available == DASH_TYPE_PLAN) $options = [DASH_TYPE_PLAN => 'План'];
  if ($type_available == DASH_TYPE_FACT) $options = [DASH_TYPE_FACT => 'Факт'];
  $form['type'] = [
    '#type' => 'select',
    '#options' => $options,
    '#prefix' => '<div class="col-xs-12 col-md-3">',
    '#suffix' => '</div>',
    '#ajax' => [
      'callback' => 'reports_ship_ship_data_edit_form_callback',
      'wrapper' => 'data-ship-edit-wrapper',
    ],
  ];

  // если изменены месяц/год, определить наличие данных
  $is_month_selected = false;
  $record_id = 0;
  if (isset($form_state['triggering_element']['#name']) && in_array($form_state['triggering_element']['#name'], ['month', 'year', 'type'])) {
    $amount_default = $qty_default = 0;
    if ($form_state['values']['month'] && $form_state['values']['year']) $is_month_selected = true;

    if ($is_month_selected) {
      $period = [
        'from' => gmmktime(0, 0, 0, (int)$form_state['values']['month'], 1, (int)$form_state['values']['year']),
        'to' => gmmktime(0, 0, 0, (int)$form_state['values']['month']+1, 1, (int)$form_state['values']['year']),
      ];
      if ($data = dash_ship_ship_get_by_conditions(['company_id' => $company_id, 'period' => $period, 'manual' => 1, 'type' => $form_state['values']['type']])) {
        $record = reset($data);
        $qty_default = $record->qty;
        $amount_default = $record->amount;
        $record_id = $record->id;
      }
    }
    $form_state['input']['qty'] = $qty_default;
    $form_state['values']['qty'] = $qty_default;
    $form_state['input']['amount'] = $amount_default;
    $form_state['values']['amount'] = $amount_default;
  }

  // id записи, если найдена существующая
  $form['record'] = [
    '#type' => 'hidden',
    '#value' => $record_id,
  ];
  // от какой компании создаётся запись
  $form['company_id'] = [
    '#type' => 'hidden',
    '#value' => $company_id,
  ];

  $form['amount'] = [
    '#type' => 'textfield',
    '#size' => 20,
    '#title' => 'Сумма (руб.)',
    '#required' => true,
    '#default_value' => 0,
