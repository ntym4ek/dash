    '#value' => 'Отправить',
    '#attributes' => ['class' => ['btn-primary', 'btn-wide']],
    '#disabled' => !$is_month_selected,
    '#ajax' => [
      'callback' => 'reports_ship_ship_data_edit_form_callback',
      'wrapper' => 'data-ship-edit-wrapper',
    ],
  ];

  return $form;
}
