function reports_goto_front()
{
  drupal_goto('<front>');
}

/**
 * hook_import_processors_alter
 */
function reports_import_processors_alter(&$processors)
{
  $path = drupal_get_path('module', 'reports') . '/includes/';

  // Справочник Статей расходов
  $processors['first_queue'][] = ['mask' => '/^scrum_hb_outcome_categories_.*\.json/',  'include' => $path . 'import.reports.inc', 'func' => 'reports_outcome_categories_import', 'archive' => 'dash/rp'];

  // План и факт прихода ДС
  $processors['last_queue'][] = ['mask' => '/^scrum_cash_income_.*\.json/',             'include' => $path . 'import.reports.inc', 'func' => 'reports_cash_income_import', 'archive' => 'dash/rp'];
  // План и факт расхода ДС
  $processors['last_queue'][] = ['mask' => '/^scrum_cash_outcome_.*\.json/',            'include' => $path . 'import.reports.inc', 'func' => 'reports_cash_outcome_import', 'archive' => 'dash/rp'];
  // Кредиты и задолженности (из бухгалтерии)
//  $processors['last_queue'][] = ['mask' => '/^scrum_debt_.*\.json/',                    'include' => $path . 'import.reports.inc', 'func' => 'reports_debt_import', 'archive' => 'dash/rp'];
  $processors['last_queue'][] = ['mask' => '/^scrum_debt_\d+_\w\w\w_.*\.json/',         'include' => $path . 'import.reports.inc', 'func' => 'reports_debt_import', 'archive' => 'dash/rp'];
  // Остатки готовой продукции и сырья
  $processors['last_queue'][] = ['mask' => '/^scrum_remains_brief_\d.*\.json/',         'include' => $path . 'import.reports.inc', 'func' => 'reports_remains_brief_import', 'archive' => 'dash/rp'];
  // Производство/Клиенты
  $processors['last_queue'][] = ['mask' => '/^scrum_production_clients_\w_\d.*\.json/', 'include' => $path . 'import.reports.inc', 'func' => 'reports_production_clients_import', 'archive' => 'dash/rp'];
  // Производство/Производство (только объёмы)
  $processors['last_queue'][] = ['mask' => '/^scrum_production_volume_\w_\d.*\.json/',  'include' => $path . 'import.reports.inc', 'func' => 'reports_production_production_import', 'archive' => 'dash/rp'];
  // Отгрузка
  //   todo перевести scrum_td_shipplan_ => dep_2v_2g_import_ship_plan_td на этот импорт
  $processors['last_queue'][] = ['mask' => '/^scrum_ship_\w_.*\.json/',                 'include' => $path . 'import.reports.inc', 'func' => 'reports_ship_import', 'archive' => 'dash/rp'];
}

/**
 * ----- Формы --------------------------------------------------------------------------------------------------------
 */

function reports_manual_bdr_data_edit_form($form, &$form_state)
{
  // сохраняем блоки, которые нужно обновить
  if (!empty($_GET["blocks"])) {
    $form_state['blocks'] = $_GET["blocks"];
  }

  // определяем ID компании, для которой заполняется форма
  if (empty($form_state["values"]['company_id'])) {
    $company_id = $_GET["inn"] ?? null;
    if (isset($company_id)) {
      $company = dash_term_get_by_1c_id('companies', $_GET["inn"]);
      $company_id = $company->tid;
    }
  } else $company_id = $form_state["values"]['company_id'];

  $form = [
    '#prefix' => '<div id="data-manual-bdr-edit-wrapper" class="data-manual-bdr-edit-wrapper">',
    '#suffix' => '</div>',
  ];

  if (empty($company_id)) {
    $intro = '<p>Не задан идентификатор компании. Обратитесь к администратору сайта.</p>';
    $form['intro'] = ['#markup' => '<div class="intro">' . $intro . '</div>'];

    return $form;
  }

  $intro = '<p>Форма позволяет добавлять новые и&nbsp;редактировать ранее введённые данные. Только числовые значения. Рублёвые значения в млн без НДС.</p>' .
  '<p class="text-danger">ВНИМАНИЕ! Вносить итоговые значения, значения не суммируются.</p>';
  $form['intro'] = [
    '#markup' => '<div class="intro">' . $intro . '</div>',
    '#attached' => ['js' => [[
      'data' => ['messages' => ['position' => 'inline']],
      'type' => 'setting',
    ]]],
  ];

  $options_m = [0 => ' - Месяц - '];
  for($i = 1; $i <= 12; $i++) {
    $options_m[$i] = helper_month_label_ru($i);
  }
  $form['month']['month'] = [
    '#type' => 'select',
    '#options' => $options_m,
    '#default_value' => 0,
    '#prefix' => '<div class="row"><div class="col-xs-7 col-md-5">',
    '#suffix' => '</div>',
    '#ajax' => [
      'callback' => 'reports_manual_bdr_data_edit_form_callback',
      'wrapper' => 'data-manual-bdr-edit-wrapper',
    ],
  ];

  $options_y = [0 => ' - Год - '];
  for($i = DASH_HISTORY_START_YEAR_TD; $i <= date('Y'); $i++) {
    $options_y[$i] = $i;
  }
  $form['month']['year'] = [
    '#type' => 'select',
    '#options' => $options_y,
    '#default_value' => 0,
    '#prefix' => '<div class="col-xs-5 col-md-4">',
    '#suffix' => '</div>',
    '#ajax' => [
      'callback' => 'reports_manual_bdr_data_edit_form_callback',
      'wrapper' => 'data-manual-bdr-edit-wrapper',
    ],
  ];

  $form['type'] = [
    '#type' => 'select',
    '#options' => [DASH_TYPE_PLAN => 'План', DASH_TYPE_FACT => 'Факт'],
    '#prefix' => '<div class="col-xs-12 col-md-3">',
    '#suffix' => '</div>',
    '#ajax' => [
      'callback' => 'reports_manual_bdr_data_edit_form_callback',
      'wrapper' => 'data-manual-bdr-edit-wrapper',
    ],
  ];

  $options_c = [];
  $terms = taxonomy_get_tree(taxonomy_vocabulary_machine_name_load('bdr')->vid);
  foreach ($terms as $term) {
    $label = $term->name;
    if ($term->depth) {
      $label = ' ' . $label;
      for($i=1; $i <= $term->depth; $i++) { $label = '-' . $label; }
    }
    $options_c[$term->tid] = $label;
  }
  $form['category'] = [
    '#type' => 'select',
    '#title' => 'Статья бюджета',
    '#options' => $options_c,
    '#prefix' => '<div class="col-xs-6">',
    '#suffix' => '</div>',
    '#ajax' => [
      'callback' => 'reports_manual_bdr_data_edit_form_callback',
      'wrapper' => 'data-manual-bdr-edit-wrapper',
    ],
  ];

  // если изменены месяц/год, определить наличие данных
  $is_month_selected = false;
  $record_id = 0;
  if (isset($form_state['triggering_element']['#name']) && in_array($form_state['triggering_element']['#name'], ['month', 'year', 'type', 'category'])) {
    $amount_default = 0;
    if ($form_state['values']['month'] && $form_state['values']['year']) $is_month_selected = true;

    if ($is_month_selected) {
      $period = [
        'from' => gmmktime(0, 0, 0, (int)$form_state['values']['month'], 1, (int)$form_state['values']['year']),
        'to' => gmmktime(0, 0, 0, (int)$form_state['values']['month']+1, 1, (int)$form_state['values']['year']),
      ];
      if ($data = dash_manual_bdr_get_by_conditions(['company_id' => $company_id, 'period' => $period, 'type' => $form_state['values']['type'],'category_ids' => [$form_state['values']['category']]])) {
        $record = reset($data);
        $amount_default = $record->amount;
        $record_id = $record->id;
      }
    }
    $form_state['input']['amount'] = $amount_default;
    $form_state['values']['amount'] = $amount_default;
  }

  // id записи, если найдена существующая
  $form['record'] = [
    '#type' => 'hidden',
    '#value' => $record_id,
  ];
  // от какой компании создаётся запись
  $form['company_id'] = [
    '#type' => 'hidden',
    '#value' => $company_id,
  ];

  $form['amount'] = [
    '#type' => 'textfield',
    '#size' => 20,
    '#title' => 'Числовое значение',
    '#required' => true,
    '#default_value' => '',
    '#disabled' => !$is_month_selected,
    '#prefix' => '<div class="col-xs-6">',
    '#suffix' => '</div></div>',
  ];

  $form['actions'] = ['#type' => 'actions'];
  $form['actions']['submit'] = [
    '#type' => 'submit',
    '#value' => 'Отправить',
    '#attributes' => ['class' => ['btn-primary', 'btn-wide']],
    '#disabled' => !$is_month_selected,
    '#ajax' => [
      'callback' => 'reports_manual_bdr_data_edit_form_callback',
      'wrapper' => 'data-manual-bdr-edit-wrapper',
    ],
  ];

  return $form;
}
function reports_manual_bdr_data_edit_form_callback($form, $form_state)
{
  return $form;
}
function reports_manual_bdr_data_edit_form_submit($form, $form_state)
{
  $month_start = gmmktime(0, 0, 0, (int)$form_state['values']['month'], 1, (int)$form_state['values']['year']);

  // удалить старые записи за месяц
  if ($form_state['values']['record']) {
    entity_delete('manual', $form_state['values']['record']);
  }

  // добавить Запись плана
  $record = dash_manual_bdr_create([
    'created' => REQUEST_TIME,
    'company_id' => $form_state['values']['company_id'],
    'month_ts' => $month_start,
    'type' => $form_state['values']['type'],
    'category_id' => $form_state['values']['category'],
    'amount' => $form_state['values']['amount'],
  ]);

  // обновление блоков
  if (!empty($form_state['blocks'])) {
    foreach ($form_state['blocks'] as $block) {
      $block = check_plain($block);
      $output = '<div class="ajax-load" data-func="' . $block . '"><div class="ajax-progress ajax-progress-throbber"><div class="throbber">&nbsp;</div><div class="message">Пожалуйста, подождите...</div></div></div>';
      $commands[] = ajax_command_replace('[data-func="' . $block . '"]', $output);
    }
  }

  $commands[] = ajax_command_invoke('.autodialog-content', 'dialog', array('close'));
  ctools_include('ajax');
  ctools_add_js('ajax-responder');
  print ajax_render($commands);
  drupal_exit();
}

function reports_prod_prod_data_edit_form($form, &$form_state)
{
  // сохраняем блоки, которые нужно обновить
  if (!empty($_GET["blocks"])) {
    $form_state['blocks'] = $_GET["blocks"];
  }

  // определяем ID компании, для которой заполняется форма
  if (empty($form_state["values"]['company_id'])) {
    $company_id = $_GET["inn"] ?? null;
    if (isset($company_id)) {
      $company = dash_term_get_by_1c_id('companies', $_GET["inn"]);
      $company_id = $company->tid;
    }
  } else $company_id = $form_state["values"]['company_id'];

  $form = [
    '#prefix' => '<div id="data-prod-prod-edit-wrapper" class="data-prod-prod-edit-wrapper">',
    '#suffix' => '</div>',
  ];

  // тип записей, которые доступны пользователю
  $type_available = $form_state["values"]["type_available"] ?? $_GET["type"] ?? 0;
  $form['type_available'] = [
    '#type' => 'hidden',
    '#value' => $type_available,
  ];

  if (empty($company_id)) {
    $intro = '<p>Не задан идентификатор компании. Обратитесь к администратору сайта.</p>';
    $form['intro'] = ['#markup' => '<div class="intro">' . $intro . '</div>'];

    return $form;
  }

  $intro = '<p>Форма позволяет добавлять новые и&nbsp;редактировать ранее введённые данные. Данные вводятся помесячно. Только числовые значения.</p>';
  $form['intro'] = [
    '#markup' => '<div class="intro">' . $intro . '</div>',
    '#attached' => ['js' => [[
      'data' => ['messages' => ['position' => 'inline']],
      'type' => 'setting',
    ]]],
  ];

  $options_m = [0 => ' - Месяц - '];
  for($i = 1; $i <= 12; $i++) {
    $options_m[$i] = helper_month_label_ru($i);
  }
  $form['month']['month'] = [
    '#type' => 'select',
    '#options' => $options_m,
    '#default_value' => 0,
    '#prefix' => '<div class="row"><div class="col-xs-7 col-md-5">',
    '#suffix' => '</div>',
    '#ajax' => [
      'callback' => 'reports_prod_prod_data_edit_form_callback',
      'wrapper' => 'data-prod-prod-edit-wrapper',
    ],
  ];

  $options_y = [0 => ' - Год - '];
  for($i = DASH_HISTORY_START_YEAR_AH; $i <= date('Y'); $i++) {
    $options_y[$i] = $i;
  }
  $form['month']['year'] = [
    '#type' => 'select',
    '#options' => $options_y,
    '#default_value' => 0,
    '#prefix' => '<div class="col-xs-5 col-md-4">',
    '#suffix' => '</div>',
    '#ajax' => [
      'callback' => 'reports_prod_prod_data_edit_form_callback',
      'wrapper' => 'data-prod-prod-edit-wrapper',
    ],
  ];

  // где-то может быть доступно занесение только одного типа данных
  $options = [DASH_TYPE_PLAN => 'План', DASH_TYPE_FACT => 'Факт'];
  if ($type_available == DASH_TYPE_PLAN) $options = [DASH_TYPE_PLAN => 'План'];
  if ($type_available == DASH_TYPE_FACT) $options = [DASH_TYPE_FACT => 'Факт'];
  $form['type'] = [
    '#type' => 'select',
    '#options' => $options,
    '#prefix' => '<div class="col-xs-12 col-md-3">',
    '#suffix' => '</div>',
    '#ajax' => [
      'callback' => 'reports_prod_prod_data_edit_form_callback',
      'wrapper' => 'data-prod-prod-edit-wrapper',
    ],
  ];

  // если изменены месяц/год, определить наличие данных
  $is_month_selected = false;
  $record_id = 0;
  if (isset($form_state['triggering_element']['#name']) && in_array($form_state['triggering_element']['#name'], ['month', 'year', 'type'])) {
    $volume_default = 0;
    if ($form_state['values']['month'] && $form_state['values']['year']) $is_month_selected = true;

    if ($is_month_selected) {
      $period = [
        'from' => gmmktime(0, 0, 0, (int)$form_state['values']['month'], 1, (int)$form_state['values']['year']),
        'to' => gmmktime(0, 0, 0, (int)$form_state['values']['month']+1, 1, (int)$form_state['values']['year']),
      ];
      if ($data = dash_production_production_get_by_conditions(['company_id' => $company_id, 'period' => $period, 'type' => $form_state['values']['type']])) {
        $record = reset($data);
        $volume_default = $record->volume;
        $record_id = $record->id;
      }
    }
    $form_state['input']['volume'] = $volume_default;
    $form_state['values']['volume'] = $volume_default;
  }

  // id записи, если найдена существующая
  $form['record'] = [
    '#type' => 'hidden',
    '#value' => $record_id,
  ];
  // от какой компании создаётся запись
  $form['company_id'] = [
    '#type' => 'hidden',
    '#value' => $company_id,
  ];

  $form['volume'] = [
    '#type' => 'textfield',
    '#size' => 20,
    '#title' => 'Объём (л/кг/шт)',
    '#required' => true,
    '#default_value' => '',
    '#disabled' => !$is_month_selected,
    '#prefix' => '<div class="col-xs-6">',
    '#suffix' => '</div></div>',
  ];

  $form['actions'] = ['#type' => 'actions'];
  $form['actions']['submit'] = [
    '#type' => 'submit',
    '#value' => 'Отправить',
    '#attributes' => ['class' => ['btn-primary', 'btn-wide']],
    '#disabled' => !$is_month_selected,
    '#ajax' => [
      'callback' => 'reports_prod_prod_data_edit_form_callback',
      'wrapper' => 'data-prod-prod-edit-wrapper',
    ],
  ];

  return $form;
}
