function reports_manual_production_by_directions_data_edit_form($form, &$form_state)
{
  // сохраняем блоки, которые нужно обновить
  if (!empty($_GET["blocks"])) {
    $form_state['blocks'] = $_GET["blocks"];
  }

  // определяем ID компании, для которой заполняется форма
  if (empty($form_state["values"]['company_id'])) {
    $company_id = $_GET["inn"] ?? null;
    if (isset($company_id)) {
      $company = dash_term_get_by_1c_id('companies', $_GET["inn"]);
      $company_id = $company->tid;
    }
  } else $company_id = $form_state["values"]['company_id'];

  $form = [
    '#prefix' => '<div id="data-manual-production-by-directions-edit-wrapper" class="data-manual-production-by-directions-edit-wrapper">',
    '#suffix' => '</div>',
  ];

  if (empty($company_id)) {
    $intro = '<p>Не задан идентификатор компании. Обратитесь к администратору сайта.</p>';
    $form['intro'] = ['#markup' => '<div class="intro">' . $intro . '</div>'];

    return $form;
  }

  $intro = '<p>Форма позволяет добавлять новые и&nbsp;редактировать ранее введённые данные. Данные вводятся помесячно. Только числовые значения. </p>';
  $form['intro'] = [
    '#markup' => '<div class="intro">' . $intro . '</div>',
    '#attached' => ['js' => [[
      'data' => ['messages' => ['position' => 'inline']],
      'type' => 'setting',
    ]]],
  ];

  $options_m = [0 => ' - Месяц - '];
  for($i = 1; $i <= 12; $i++) {
    $options_m[$i] = helper_month_label_ru($i);
  }
  $form['month']['month'] = [
    '#type' => 'select',
    '#options' => $options_m,
    '#default_value' => 0,
    '#prefix' => '<div class="row"><div class="col-xs-7 col-md-5">',
    '#suffix' => '</div>',
    '#ajax' => [
      'callback' => 'reports_manual_production_by_directions_data_edit_form_callback',
      'wrapper' => 'data-manual-production-by-directions-edit-wrapper',
    ],
  ];

  $options_y = [0 => ' - Год - '];
  for($i = DASH_HISTORY_START_YEAR_AH; $i <= date('Y'); $i++) {
    $options_y[$i] = $i;
  }
  $form['month']['year'] = [
    '#type' => 'select',
    '#options' => $options_y,
    '#default_value' => 0,
    '#prefix' => '<div class="col-xs-5 col-md-4">',
    '#suffix' => '</div>',
    '#ajax' => [
      'callback' => 'reports_manual_production_by_directions_data_edit_form_callback',
      'wrapper' => 'data-manual-production-by-directions-edit-wrapper',
    ],
  ];

  $form['type'] = [
    '#type' => 'select',
    '#options' => [DASH_TYPE_PLAN => 'План', DASH_TYPE_FACT => 'Факт'],
    '#prefix' => '<div class="col-xs-12 col-md-3">',
    '#suffix' => '</div>',
    '#ajax' => [
      'callback' => 'reports_manual_production_by_directions_data_edit_form_callback',
      'wrapper' => 'data-manual-production-by-directions-edit-wrapper',
    ],
  ];

  $options_d = [];
  $terms = taxonomy_get_tree(taxonomy_vocabulary_machine_name_load('directions_manual')->vid);
  foreach ($terms as $term) {
    $options_d[$term->tid] = $term->name;
  }
  $form['direction'] = [
    '#type' => 'select',
    '#title' => 'Направление',
    '#options' => $options_d,
    '#prefix' => '<div class="col-xs-6">',
    '#suffix' => '</div>',
    '#ajax' => [
      'callback' => 'reports_manual_production_by_directions_data_edit_form_callback',
      'wrapper' => 'data-manual-production-by-directions-edit-wrapper',
    ],
  ];

  // если изменены месяц/год, определить наличие данных
  $is_month_selected = false;
  $record_id = 0;
  if (isset($form_state['triggering_element']['#name']) && in_array($form_state['triggering_element']['#name'], ['month', 'year', 'type', 'direction'])) {
    $volume_default = 0;
    if ($form_state['values']['month'] && $form_state['values']['year']) $is_month_selected = true;

    if ($is_month_selected) {
      $period = [
        'from' => gmmktime(0, 0, 0, (int)$form_state['values']['month'], 1, (int)$form_state['values']['year']),
        'to' => gmmktime(0, 0, 0, (int)$form_state['values']['month']+1, 1, (int)$form_state['values']['year']),
      ];
      if ($data = dash_manual_production_by_directions_get_by_conditions(['company_id' => $company_id, 'period' => $period, 'type' => $form_state['values']['type'],'direction_id' => $form_state['values']['direction']])) {
        $record = reset($data);
        $volume_default = $record->volume;
        $record_id = $record->id;
      }
    }
    $form_state['input']['volume'] = $volume_default;
    $form_state['values']['volume'] = $volume_default;
  }

  // id записи, если найдена существующая
  $form['record'] = [
    '#type' => 'hidden',
    '#value' => $record_id,
  ];
  // от какой компании создаётся запись
  $form['company_id'] = [
    '#type' => 'hidden',
    '#value' => $company_id,
  ];

  $form['volume'] = [
    '#type' => 'textfield',
    '#size' => 20,
    '#title' => 'Объём (л/кг/шт)',
    '#required' => true,
    '#default_value' => '',
    '#disabled' => !$is_month_selected,
    '#prefix' => '<div class="col-xs-6">',
    '#suffix' => '</div></div>',
  ];

  $form['actions'] = ['#type' => 'actions'];
  $form['actions']['submit'] = [
    '#type' => 'submit',
    '#value' => 'Отправить',
    '#attributes' => ['class' => ['btn-primary', 'btn-wide']],
    '#disabled' => !$is_month_selected,
    '#ajax' => [
      'callback' => 'reports_manual_production_by_directions_data_edit_form_callback',
      'wrapper' => 'data-manual-production-by-directions-edit-wrapper',
    ],
  ];

  return $form;
}
