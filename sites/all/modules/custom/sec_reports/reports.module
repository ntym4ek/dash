  $commands[] = ajax_command_invoke('.autodialog-content', 'dialog', array('close'));
  ctools_include('ajax');
  ctools_add_js('ajax-responder');
  print ajax_render($commands);
  drupal_exit();
}

function reports_plan_prod_data_edit_form($form, &$form_state)
{
  // сохраняем блоки, которые нужно обновить
  if (!empty($_GET["blocks"])) {
    $form_state['blocks'] = $_GET["blocks"];
  }

  $form = [
    '#prefix' => '<div id="data-plan-prod-edit-wrapper" class="data-plan-prod-edit-wrapper">',
    '#suffix' => '</div>',
  ];

  $intro = '<p>Форма позволяет добавлять новые и&nbsp;редактировать ранее введённые данные</p>';

  $form['intro'] = [
    '#markup' => '<div class="intro">' . $intro . '</div>',
    '#attached' => ['js' => [[
      'data' => ['messages' => ['position' => 'inline']],
      'type' => 'setting',
    ]]],
  ];

  $options_m = [0 => ' - Месяц - '];
  for($i = 1; $i <= 12; $i++) {
    $options_m[$i] = helper_month_label_ru($i);
  }
  $form['month']['month'] = [
    '#type' => 'select',
    '#options' => $options_m,
    '#default_value' => 0,
    '#prefix' => '<div class="row"><div class="col-xs-7">',
    '#suffix' => '</div>',
    '#ajax' => [
      'callback' => 'reports_plan_prod_data_edit_form_callback',
      'wrapper' => 'data-plan-prod-edit-wrapper',
    ],
  ];

  $options_y = [0 => ' - Год - '];
  for($i = DASH_HISTORY_START_YEAR_TD; $i <= date('Y'); $i++) {
    $options_y[$i] = $i;
  }
  $form['month']['year'] = [
    '#type' => 'select',
    '#options' => $options_y,
    '#default_value' => 0,
    '#prefix' => '<div class="col-xs-5">',
    '#suffix' => '</div>',
    '#ajax' => [
      'callback' => 'reports_plan_prod_data_edit_form_callback',
      'wrapper' => 'data-plan-prod-edit-wrapper',
    ],
  ];

  // где-то может быть доступно занесение только одного типа данных
  $options = [0 => 'План', 1 => 'Факт'];
  if (!empty($_GET["type"])) {
    if ($_GET["type"] == DASH_TYPE_PLAN) $options = [0 => 'План'];
    if ($_GET["type"] == DASH_TYPE_FACT) $options = [1 => 'Факт'];
  }
  $form['fact'] = [
    '#type' => 'select',
    '#title' => 'Тип записи',
    '#options' => $options,
    '#prefix' => '<div class="col-xs-6">',
    '#suffix' => '</div>',
    '#ajax' => [
      'callback' => 'reports_plan_prod_data_edit_form_callback',
      'wrapper' => 'data-plan-prod-edit-wrapper',
    ],
  ];

  // если изменены месяц/год, определить наличие данных
  $is_month_selected = false;
  $record_id = 0;
  if (isset($form_state['triggering_element']['#name']) && in_array($form_state['triggering_element']['#name'], ['month', 'year', 'fact'])) {
    $volume_default = 0;
    if ($form_state['values']['month'] && $form_state['values']['year']) $is_month_selected = true;

    if ($is_month_selected) {
      $period = [
        'from' => gmmktime(0, 0, 0, (int)$form_state['values']['month'], 1, (int)$form_state['values']['year']),
        'to' => gmmktime(0, 0, 0, (int)$form_state['values']['month']+1, 1, (int)$form_state['values']['year']),
      ];
      if ($data = dash_plan_prod_get_by_conditions(['period' => $period, 'manual' => 1, 'fact' => $form_state['values']['fact']])) {
        $record = reset($data);
        $volume_default = $record->output;
        $record_id = $record->id;
      }
    }
    $form_state['input']['volume'] = $volume_default;
    $form_state['values']['volume'] = $volume_default;
  }


  // id записи, если найдена существующая
  $form['record'] = [
    '#type' => 'hidden',
    '#value' => $record_id,
  ];

  $form['volume'] = [
    '#type' => 'textfield',
    '#size' => 20,
    '#title' => 'Объём (л/кг/шт)',
    '#required' => true,
    '#default_value' => 0,
    '#disabled' => !$is_month_selected,
    '#prefix' => '<div class="col-xs-6">',
    '#suffix' => '</div></div>',
  ];

  $form['actions'] = ['#type' => 'actions'];
  $form['actions']['submit'] = [
    '#type' => 'submit',
    '#value' => 'Отправить',
    '#attributes' => ['class' => ['btn-primary', 'btn-wide']],
    '#disabled' => !$is_month_selected,
    '#ajax' => [
      'callback' => 'reports_plan_prod_data_edit_form_callback',
      'wrapper' => 'data-plan-prod-edit-wrapper',
    ],
  ];

  return $form;
}
function reports_plan_prod_data_edit_form_callback($form, $form_state)
{
  return $form;
}
function reports_plan_prod_data_edit_form_submit($form, $form_state)
{
  $month_start = gmmktime(0, 0, 0, (int)$form_state['values']['month'], 1, (int)$form_state['values']['year']);

  // удалить старые записи за месяц
  if ($form_state['values']['record']) {
    entity_delete('plan', $form_state['values']['record']);
  }

  // добавить Запись плана
  $record = dash_plan_prod_create([
    'created' => REQUEST_TIME,
    'month_ts' => $month_start,
    'nom_id' => 0,
    'fact' => $form_state['values']['fact'],
    'manual' => 1,
    'volume' => $form_state['values']['volume'],
  ]);

  // обновление блоков
  if (!empty($form_state['blocks'])) {
    foreach ($form_state['blocks'] as $block) {
      $block = check_plain($block);
      $output = '<div class="ajax-load" data-func="' . $block . '"><div class="ajax-progress ajax-progress-throbber"><div class="throbber">&nbsp;</div><div class="message">Пожалуйста, подождите...</div></div></div>';
      $commands[] = ajax_command_replace('[data-func="' . $block . '"]', $output);
    }
  }

  $commands[] = ajax_command_invoke('.autodialog-content', 'dialog', array('close'));
  ctools_include('ajax');
  ctools_add_js('ajax-responder');
  print ajax_render($commands);
  drupal_exit();
}

